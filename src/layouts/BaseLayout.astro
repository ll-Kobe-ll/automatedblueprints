---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { site } from '../data/site';

interface Props {
  title: string;
  description: string;
  ogTitle?: string;
  ogDescription?: string;
  canonicalPath?: string;
  schema?: object | object[];
  noIndex?: boolean;
  bare?: boolean;
}

const {
  title,
  description,
  ogTitle,
  ogDescription,
  canonicalPath = Astro.url.pathname,
  schema,
  noIndex = false,
  bare = false,
} = Astro.props;

const canonicalUrl = `${site.domain}${canonicalPath}`.replace(/\/$/, '') || site.domain;
const resolvedOgTitle = ogTitle ?? title;
const resolvedOgDesc  = ogDescription ?? description;

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: site.name,
  description: site.tagline,
  url: site.domain,
  email: site.email,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Orange County',
    addressRegion: 'CA',
    addressCountry: 'US',
  },
  areaServed: 'US',
};

const allSchema = [localBusinessSchema, ...(Array.isArray(schema) ? schema : schema ? [schema] : [])];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title"       content={resolvedOgTitle} />
    <meta property="og:description" content={resolvedOgDesc} />
    <meta property="og:url"         content={canonicalUrl} />
    <meta property="og:type"        content="website" />
    <meta property="og:site_name"   content={site.name} />
    <meta property="og:image"       content={`${site.domain}/og-image.png`} />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={resolvedOgTitle} />
    <meta name="twitter:description" content={resolvedOgDesc} />
    <meta name="twitter:image"       content={`${site.domain}/og-image.png`} />

    <!-- Theme color -->
    <meta name="theme-color" content="#1a2440" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Schema.org JSON-LD -->
    {allSchema.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}
  </head>
  <body class="bg-warm text-ink antialiased">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[200] focus:px-4 focus:py-2 focus:bg-brand-600 focus:text-white focus:rounded focus:font-semibold focus:outline-none"
    >
      Skip to main content
    </a>
    {bare ? (
      <header class="bg-white border-b border-warm-200">
        <div class="section-container h-16 flex items-center">
          <a href="/" class="flex items-center gap-2.5" aria-label={`${site.name} home`}>
            <img src="/favicon.png" alt="" width="32" height="32" class="w-8 h-8 rounded-md flex-shrink-0" />
            <span class="text-ink font-bold text-lg tracking-tight">{site.name}</span>
          </a>
        </div>
      </header>
    ) : (
      <Header />
    )}
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    {!bare && <Footer />}
  </body>
</html>
