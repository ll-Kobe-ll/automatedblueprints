---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { site } from '../data/site';

interface Props {
  title: string;
  description: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  canonicalPath?: string;
  schema?: object | object[];
  noIndex?: boolean;
  bare?: boolean;
}

const {
  title,
  description,
  ogTitle,
  ogDescription,
  ogImage,
  canonicalPath = Astro.url.pathname,
  schema,
  noIndex = false,
  bare = false,
} = Astro.props;

const canonicalUrl = `${site.domain}${canonicalPath}`.replace(/\/$/, '') || site.domain;
// Mobile sticky CTA: owner-facing pages only. Skipped on bare pages (funnel/thank-you)
// and on /templates, where the audience is agencies, not local owners.
const showStickyCta = !bare && !Astro.url.pathname.startsWith('/templates');
const resolvedOgTitle = ogTitle ?? title;
const resolvedOgDesc  = ogDescription ?? description;
// Per-page OG image (absolute URL); falls back to the global card.
const resolvedOgImage = ogImage
  ? (ogImage.startsWith('http') ? ogImage : `${site.domain}${ogImage}`)
  : `${site.domain}/og-image.png`;

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: site.name,
  description: site.tagline,
  url: site.domain,
  email: site.email,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Orange County',
    addressRegion: 'CA',
    addressCountry: 'US',
  },
  areaServed: 'US',
};

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: site.name,
  url: site.domain,
  logo: `${site.domain}/favicon.png`,
  email: site.email,
  description: site.tagline,
  // Paste social profile URLs here once they exist (LinkedIn, Facebook, etc.).
  sameAs: [],
};

const allSchema = [localBusinessSchema, organizationSchema, ...(Array.isArray(schema) ? schema : schema ? [schema] : [])];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title"       content={resolvedOgTitle} />
    <meta property="og:description" content={resolvedOgDesc} />
    <meta property="og:url"         content={canonicalUrl} />
    <meta property="og:type"        content="website" />
    <meta property="og:site_name"   content={site.name} />
    <meta property="og:image"       content={resolvedOgImage} />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={resolvedOgTitle} />
    <meta name="twitter:description" content={resolvedOgDesc} />
    <meta name="twitter:image"       content={resolvedOgImage} />

    <!-- RSS feed autodiscovery -->
    <link rel="alternate" type="application/rss+xml" title={`${site.name} Blog`} href={`${site.domain}/rss.xml`} />

    <!-- Theme color -->
    <meta name="theme-color" content="#1a2440" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Schema.org JSON-LD -->
    {allSchema.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}

    <!-- Safety net: if JS is off, never hide reveal content -->
    <noscript>
      <style>.reveal { opacity: 1 !important; transform: none !important; }</style>
    </noscript>
  </head>
  <body class="bg-warm text-ink antialiased">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[200] focus:px-4 focus:py-2 focus:bg-brand-600 focus:text-white focus:rounded focus:font-semibold focus:outline-none"
    >
      Skip to main content
    </a>
    {bare ? (
      <header class="bg-white border-b border-warm-200">
        <div class="section-container h-16 flex items-center">
          <a href="/" class="flex items-center gap-2.5" aria-label={`${site.name} home`}>
            <img src="/favicon.png" alt="" width="32" height="32" class="w-8 h-8 rounded-md flex-shrink-0" />
            <span class="text-ink font-bold text-lg tracking-tight">{site.name}</span>
          </a>
        </div>
      </header>
    ) : (
      <Header />
    )}
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    {!bare && <Footer />}

    {showStickyCta && (
      <>
        <!-- Mobile sticky CTA -->
        <div class="md:hidden fixed bottom-0 inset-x-0 z-50 bg-white/95 backdrop-blur border-t border-warm-200 px-4 pt-3" style="padding-bottom: calc(0.75rem + env(safe-area-inset-bottom));">
          <a href={site.ctaHref} class="btn-primary w-full justify-center">{site.ctaText}</a>
        </div>
        <!-- Spacer so the bar never covers page content -->
        <div class="h-20 md:hidden" aria-hidden="true"></div>
      </>
    )}

    <!-- Global scroll-reveal: any element with .reveal fades up once on scroll -->
    <script>
      (() => {
        const els = document.querySelectorAll('.reveal');
        if (!els.length) return;
        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduce) {
          els.forEach((el) => el.classList.add('is-visible'));
          return;
        }
        const obs = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                obs.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
        );
        els.forEach((el) => obs.observe(el));
      })();
    </script>
  </body>
</html>
