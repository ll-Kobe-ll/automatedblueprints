---
// Live demo: review request goes out -> stars fill -> review count climbs.
// Pure client-side. Auto-plays once on scroll-in, plus a Replay button.
---

<div class="demo-reviews bg-warm-100 border border-warm-200 rounded-lg p-6 md:p-8" aria-hidden="true">
  <div class="flex items-center justify-between mb-4">
    <p class="text-xs font-semibold uppercase tracking-wider text-ink-muted">After a job is done</p>
    <button type="button" class="demo-replay inline-flex items-center gap-1.5 text-xs font-semibold text-brand-600 hover:text-brand-700 transition-colors" aria-label="Replay the reviews demo">
      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992V4.356M2.985 19.644v-4.992h4.992m-5.073-2.876a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" />
      </svg>
      Replay
    </button>
  </div>

  <!-- Request bubble -->
  <div class="demo-line demo-req flex justify-start mb-5">
    <div class="bg-brand-600 text-white text-sm rounded-2xl rounded-tl-sm px-4 py-2.5 max-w-[88%]">
      Thanks for choosing <span data-biz>[Business Name]</span>! If you have 30 seconds, a quick Google review really helps: <span class="underline">g.page/review</span>
    </div>
  </div>

  <!-- Result card -->
  <div class="demo-line demo-result bg-white border border-warm-200 rounded-lg p-4 flex items-center justify-between gap-4">
    <div>
      <div class="demo-stars flex items-center gap-0.5 mb-1" role="img" aria-label="Five star rating">
        {Array.from({ length: 5 }).map((_, i) => (
          <svg class={`demo-star demo-star-${i} w-5 h-5 text-warm-border`} fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.286 3.957a1 1 0 00.95.69h4.162c.969 0 1.371 1.24.588 1.81l-3.367 2.446a1 1 0 00-.364 1.118l1.287 3.957c.3.922-.755 1.688-1.54 1.118l-3.366-2.446a1 1 0 00-1.176 0l-3.366 2.446c-.784.57-1.838-.196-1.539-1.118l1.286-3.957a1 1 0 00-.363-1.118L2.27 9.394c-.783-.57-.38-1.81.588-1.81h4.162a1 1 0 00.95-.69l1.286-3.957z" />
          </svg>
        ))}
      </div>
      <p class="text-xs text-ink-muted">Google rating: <span class="demo-rating font-semibold text-ink">5.0</span></p>
    </div>
    <div class="text-right">
      <p class="demo-count text-2xl font-bold text-brand-600 leading-none" data-from="8" data-to="24">8</p>
      <p class="text-xs text-ink-muted mt-1">reviews</p>
    </div>
  </div>
</div>

<style>
  .demo-line { opacity: 0; transform: translateY(8px); }
  .demo-line.is-on { animation: lineIn 0.45s ease forwards; }
  @keyframes lineIn { to { opacity: 1; transform: translateY(0); } }

  .demo-star { transform: scale(0.6); transition: color 0.25s ease, transform 0.25s ease; }
  .demo-star.is-lit { color: theme('colors.amber.400'); transform: scale(1); }

  @media (prefers-reduced-motion: reduce) {
    .demo-line { opacity: 1; transform: none; animation: none; }
    .demo-star { transform: scale(1); color: theme('colors.amber.400'); transition: none; }
  }
</style>

<script>
  (() => {
    document.querySelectorAll<HTMLElement>('.demo-reviews').forEach((demo) => {
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const req = demo.querySelector<HTMLElement>('.demo-req');
      const result = demo.querySelector<HTMLElement>('.demo-result');
      const stars = demo.querySelectorAll<HTMLElement>('.demo-star');
      const count = demo.querySelector<HTMLElement>('.demo-count');
      const replay = demo.querySelector<HTMLButtonElement>('.demo-replay');
      let timers: number[] = [];
      let raf = 0;

      const clear = () => { timers.forEach((t) => clearTimeout(t)); timers = []; cancelAnimationFrame(raf); };

      const countUp = () => {
        if (!count) return;
        const from = parseInt(count.dataset.from || '0', 10);
        const to = parseInt(count.dataset.to || '0', 10);
        const dur = 1000;
        const start = performance.now();
        const tick = (now: number) => {
          const p = Math.min((now - start) / dur, 1);
          const eased = 1 - Math.pow(1 - p, 3);
          count.textContent = String(Math.round(from + (to - from) * eased));
          if (p < 1) raf = requestAnimationFrame(tick);
        };
        raf = requestAnimationFrame(tick);
      };

      const reset = () => {
        clear();
        req?.classList.remove('is-on');
        result?.classList.remove('is-on');
        stars.forEach((s) => s.classList.remove('is-lit'));
        if (count) count.textContent = count.dataset.from || '0';
      };

      const play = () => {
        if (reduce) {
          req?.classList.add('is-on'); result?.classList.add('is-on');
          stars.forEach((s) => s.classList.add('is-lit'));
          if (count) count.textContent = count.dataset.to || '0';
          return;
        }
        reset();
        timers.push(window.setTimeout(() => req?.classList.add('is-on'), 300));
        timers.push(window.setTimeout(() => result?.classList.add('is-on'), 1100));
        stars.forEach((s, i) => {
          timers.push(window.setTimeout(() => s.classList.add('is-lit'), 1500 + i * 220));
        });
        timers.push(window.setTimeout(countUp, 1600));
      };

      replay?.addEventListener('click', play);

      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => { if (e.isIntersecting) { play(); io.unobserve(e.target); } });
      }, { threshold: 0.4 });
      io.observe(demo);
    });
  })();
</script>
