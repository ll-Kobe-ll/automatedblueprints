---
import type { Project } from '../data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;
const host = project.url.replace(/^https?:\/\//, '').replace(/\/$/, '');
const isTemplate = project.type === 'template';
---

<div class="flex flex-col">
  <a
    href={project.url}
    target="_blank"
    rel="noopener noreferrer"
    class="block group"
    aria-label={`Open ${project.name} in a new tab`}
  >
    <div class="rounded-xl overflow-hidden border border-warm-200 shadow-sm group-hover:shadow-md transition-shadow bg-white">
      <!-- Browser chrome -->
      <div class="flex items-center gap-2 px-4 py-3 bg-warm-100 border-b border-warm-200">
        <span class="w-3 h-3 rounded-full bg-warm-200" aria-hidden="true"></span>
        <span class="w-3 h-3 rounded-full bg-warm-200" aria-hidden="true"></span>
        <span class="w-3 h-3 rounded-full bg-warm-200" aria-hidden="true"></span>
        <span class="ml-3 flex-1 flex items-center gap-2 bg-white border border-warm-200 rounded px-3 py-1.5 text-sm text-ink-light truncate">
          <svg class="w-3.5 h-3.5 flex-shrink-0 text-ink-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
          </svg>
          {host}
        </span>
      </div>

      {project.screenshot ? (
        <!-- Real screenshot. Fixed aspect ratio prevents layout shift. -->
        <div class="relative aspect-[16/10] bg-warm-100">
          <img
            src={project.screenshot}
            alt={`Screenshot of the ${project.name} website`}
            width="1200"
            height="750"
            loading="lazy"
            decoding="async"
            class="w-full h-full object-cover object-top"
          />
          {isTemplate && (
            <span class="absolute top-3 right-3 bg-ink/90 text-white text-xs font-semibold px-2.5 py-1 rounded">Template</span>
          )}
        </div>
      ) : (
        <!-- Styled fallback panel (no screenshot provided yet) -->
        <div class="proof-screen relative bg-ink text-white px-8 py-16 md:py-20 text-center">
          {isTemplate && (
            <span class="absolute top-3 right-3 bg-white/15 text-white text-xs font-semibold px-2.5 py-1 rounded">Template</span>
          )}
          <p class="text-brand-300 text-xs font-semibold uppercase tracking-wider mb-4">{project.descriptor}</p>
          <p class="text-white text-2xl md:text-3xl font-bold tracking-tight mb-6">{project.name}</p>
          <span class="inline-flex items-center gap-2 bg-white text-brand-700 font-semibold px-6 py-3 rounded group-hover:bg-brand-50 transition-colors">
            Visit the live site
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </span>
        </div>
      )}
    </div>
  </a>

  <p class="text-ink-light text-sm mt-5 leading-relaxed">
    {project.caption}
  </p>
</div>
