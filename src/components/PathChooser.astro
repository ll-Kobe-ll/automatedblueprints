---
interface Props {
  heading?: string;
  sub?: string;
  variant?: 'white' | 'warm';
}

const {
  heading = 'What Do You Need?',
  sub = 'Two ways to work with us. Pick the one that fits where you are.',
  variant = 'white',
} = Astro.props;

const paths = [
  {
    tag: 'Free',
    title: 'Fix My Lead Flow',
    desc: 'A free audit of where you are losing jobs to slow response, plus a personalized video on what to change.',
    href: '/audit',
    cta: 'Get the free audit',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />`,
  },
  {
    tag: 'Done For You',
    title: 'The Lead Flow System',
    desc: 'The website, missed-call text-back, follow-up, and reviews. Built and run for you, live proof included.',
    href: '/pricing',
    cta: 'See plans & pricing',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" />`,
  },
];
---

<section
  class:list={['section-pad', variant === 'warm' ? 'bg-warm-100 border-y border-warm-200' : 'bg-white']}
  aria-labelledby="paths-heading"
>
  <div class="section-container">
    <h2 id="paths-heading" class="section-heading mb-4 text-center fade-up">{heading}</h2>
    <p class="section-sub max-w-2xl mx-auto mb-16 text-center fade-up">{sub}</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-3xl mx-auto">
      {paths.map((p, i) => (
        <a
          href={p.href}
          class="path-card flex flex-col bg-white border border-warm-200 rounded-lg p-7 transition-all group fade-up"
          style={`--delay: ${i * 80}ms`}
        >
          <div class="w-10 h-10 rounded-md bg-brand-50 flex items-center justify-center mb-5 group-hover:bg-brand-100 transition-colors">
            <svg class="w-5 h-5 text-brand-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true" set:html={p.icon} />
          </div>
          <span class="text-xs font-semibold uppercase tracking-wider text-brand-600 mb-3">{p.tag}</span>
          <h3 class="text-lg font-semibold text-ink mb-3 group-hover:text-brand-600 transition-colors leading-snug">
            {p.title}
          </h3>
          <p class="text-ink-light text-sm leading-relaxed mb-6 flex-1">{p.desc}</p>
          <span class="text-brand-600 text-sm font-semibold group-hover:translate-x-1 transition-transform inline-flex items-center gap-1">
            {p.cta} <span aria-hidden="true">&rarr;</span>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .path-card {
    cursor: pointer;
  }
  .path-card:hover {
    border-color: var(--brand-600, #2563eb);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
    transform: translateY(-3px);
  }

  /* Scroll-reveal: start hidden, animate in when .is-visible is added */
  .fade-up {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s ease, transform 0.5s ease;
    transition-delay: var(--delay, 0ms);
  }
  .fade-up.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
  );

  document.querySelectorAll('.fade-up').forEach((el) => observer.observe(el));
</script>
