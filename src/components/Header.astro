---
import { site } from '../data/site';

const { pathname } = Astro.url;

function isActive(path: string): boolean {
  if (path === '/') return pathname === '/';
  return pathname === path || pathname.startsWith(path + '/');
}

const navLinkClass = (path: string) =>
  isActive(path) ? 'nav-link-active' : 'nav-link';
---

<header class="bg-white border-b border-warm-200 sticky top-0 z-50">
  <div class="section-container">
    <div class="flex items-center justify-between h-16 md:h-20">

      <!-- Wordmark -->
      <a
        href="/"
        class="group flex items-center gap-2.5"
        aria-label={`${site.name} home`}
      >
        <img src="/favicon.png" alt="" width="36" height="36" class="w-8 h-8 md:w-9 md:h-9 rounded-md flex-shrink-0" />
        <span class="text-ink font-bold text-lg md:text-xl tracking-tight group-hover:text-brand-600 transition-colors">
          {site.name}
        </span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-6" aria-label="Main navigation">
        <!-- Products dropdown -->
        <div class="relative group">
          <button
            id="products-toggle"
            class={`${isActive('/pricing') || isActive('/how-it-works') ? 'nav-link-active' : 'nav-link'} flex items-center gap-1 py-2`}
            aria-haspopup="true"
            aria-expanded="false"
            aria-controls="products-menu"
          >
            Products
            <svg class="w-4 h-4 mt-0.5 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div id="products-menu" class="absolute top-full left-0 mt-1 w-60 bg-white border border-warm-200 rounded-lg shadow-lg invisible opacity-0 group-hover:visible group-hover:opacity-100 transition-all duration-150 z-50">
            <a href="/pricing" class="block px-4 py-3.5 hover:bg-warm rounded-t-lg transition-colors">
              <span class="block font-medium text-ink text-sm">Plans &amp; Pricing</span>
              <span class="text-xs text-ink-muted">The website and the system, priced simply</span>
            </a>
            <a href="/how-it-works" class="block px-4 py-3.5 hover:bg-warm rounded-b-lg transition-colors border-t border-warm-200">
              <span class="block font-medium text-ink text-sm">How It Works</span>
              <span class="text-xs text-ink-muted">Watch the system run, live</span>
            </a>
          </div>
        </div>

        <!-- Learn dropdown -->
        <div class="relative group">
          <button
            id="learn-toggle"
            class={`${isActive('/learn') || isActive('/blog') || isActive('/industries') ? 'nav-link-active' : 'nav-link'} flex items-center gap-1 py-2`}
            aria-haspopup="true"
            aria-expanded="false"
            aria-controls="learn-menu"
          >
            Learn
            <svg class="w-4 h-4 mt-0.5 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div id="learn-menu" class="absolute top-full left-0 mt-1 w-64 bg-white border border-warm-200 rounded-lg shadow-lg invisible opacity-0 group-hover:visible group-hover:opacity-100 transition-all duration-150 z-50">
            <a href="/blog" class="block px-4 py-3.5 hover:bg-warm rounded-t-lg transition-colors">
              <span class="block font-medium text-ink text-sm">Blog</span>
              <span class="text-xs text-ink-muted">Guides on websites, SEO, and leads</span>
            </a>
            <a href="/learn" class="block px-4 py-3.5 hover:bg-warm transition-colors border-t border-warm-200">
              <span class="block font-medium text-ink text-sm">Free Crash Course</span>
              <span class="text-xs text-ink-muted">Six short lessons, no email needed</span>
            </a>
            <p class="px-4 pt-3 pb-1.5 text-xs font-semibold text-ink-muted uppercase tracking-wider border-t border-warm-200">By Industry</p>
            <a href="/industries/precision-manufacturing" class="block px-4 py-2.5 hover:bg-warm transition-colors">
              <span class="block font-medium text-ink text-sm">Machine Shops &amp; Fabricators</span>
            </a>
            <a href="/industries/med-spas" class="block px-4 py-2.5 hover:bg-warm transition-colors">
              <span class="block font-medium text-ink text-sm">Med Spas &amp; Aesthetics</span>
            </a>
            <a href="/industries/home-services" class="block px-4 py-2.5 pb-3.5 hover:bg-warm rounded-b-lg transition-colors">
              <span class="block font-medium text-ink text-sm">Contractors &amp; Home Services</span>
            </a>
          </div>
        </div>

        <a href="/about"        class={navLinkClass('/about')}>About</a>
        <a href={site.ctaHref}  class="btn-primary text-sm py-2.5 px-5 whitespace-nowrap">{site.ctaShort}</a>
      </nav>

      <!-- Mobile: CTA + hamburger -->
      <div class="flex items-center gap-3 lg:hidden">
        <a href={site.ctaHref} class="btn-primary text-sm py-2 px-4 hidden sm:inline-flex whitespace-nowrap">{site.ctaShort}</a>
        <button
          id="menu-toggle"
          class="p-2 text-ink hover:text-brand-600 transition-colors"
          aria-label="Toggle navigation menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg id="icon-open" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="icon-close" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-warm-200 bg-white" aria-label="Mobile navigation">
    <nav class="section-container py-4 flex flex-col gap-1">
      <p class="text-xs font-semibold text-ink-muted uppercase tracking-wider px-3 py-2">Products</p>
      <a href="/pricing"     class="px-3 py-2.5 text-ink-light hover:text-ink hover:bg-warm rounded transition-colors">Plans &amp; Pricing</a>
      <a href="/how-it-works" class="px-3 py-2.5 text-ink-light hover:text-ink hover:bg-warm rounded transition-colors">How It Works</a>
      <div class="my-1 border-t border-warm-200"></div>
      <p class="text-xs font-semibold text-ink-muted uppercase tracking-wider px-3 py-2">Learn</p>
      <a href="/blog"         class="px-3 py-2.5 text-ink-light hover:text-ink hover:bg-warm rounded transition-colors">Blog</a>
      <a href="/learn"        class="px-3 py-2.5 text-ink-light hover:text-ink hover:bg-warm rounded transition-colors">Crash Course</a>
      <a href="/industries/precision-manufacturing" class="px-3 py-2.5 text-ink-light hover:text-ink hover:bg-warm rounded transition-colors">Machine Shops &amp; Fabricators</a>
      <a href="/industries/med-spas"                class="px-3 py-2.5 text-ink-light hover:text-ink hover:bg-warm rounded transition-colors">Med Spas &amp; Aesthetics</a>
      <a href="/industries/home-services"           class="px-3 py-2.5 text-ink-light hover:text-ink hover:bg-warm rounded transition-colors">Contractors &amp; Home Services</a>
      <div class="my-1 border-t border-warm-200"></div>
      <a href="/about"        class="px-3 py-2.5 text-ink-light hover:text-ink hover:bg-warm rounded transition-colors">About</a>
      <div class="pt-2">
        <a href={site.ctaHref} class="btn-primary w-full justify-center">{site.ctaText}</a>
      </div>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu   = document.getElementById('mobile-menu');
  const iconOpen  = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });

  // Close on outside click
  document.addEventListener('click', (e) => {
    if (!toggle?.contains(e.target as Node) && !menu?.contains(e.target as Node)) {
      menu?.classList.add('hidden');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
    }
  });

  // Products dropdown: keyboard + click support (hover still works via CSS)
  const prdToggle = document.getElementById('products-toggle');
  const prdMenu   = document.getElementById('products-menu');

  const prdOpen  = () => { prdMenu?.classList.remove('invisible', 'opacity-0'); prdToggle?.setAttribute('aria-expanded', 'true'); };
  const prdClose = () => { prdMenu?.classList.add('invisible', 'opacity-0'); prdToggle?.setAttribute('aria-expanded', 'false'); };

  prdToggle?.addEventListener('click', () => {
    prdMenu?.classList.contains('invisible') ? prdOpen() : prdClose();
  });

  document.addEventListener('keydown', (e) => {
    if ((e as KeyboardEvent).key === 'Escape') prdClose();
  });

  document.addEventListener('click', (e) => {
    if (!prdToggle?.contains(e.target as Node) && !prdMenu?.contains(e.target as Node)) prdClose();
  });

  // Learn dropdown: keyboard + click support (hover still works via CSS)
  const lrnToggle = document.getElementById('learn-toggle');
  const lrnMenu   = document.getElementById('learn-menu');

  const lrnOpen  = () => { lrnMenu?.classList.remove('invisible', 'opacity-0'); lrnToggle?.setAttribute('aria-expanded', 'true'); };
  const lrnClose = () => { lrnMenu?.classList.add('invisible', 'opacity-0'); lrnToggle?.setAttribute('aria-expanded', 'false'); };

  lrnToggle?.addEventListener('click', () => {
    lrnMenu?.classList.contains('invisible') ? lrnOpen() : lrnClose();
  });

  document.addEventListener('keydown', (e) => {
    if ((e as KeyboardEvent).key === 'Escape') lrnClose();
  });

  document.addEventListener('click', (e) => {
    if (!lrnToggle?.contains(e.target as Node) && !lrnMenu?.contains(e.target as Node)) lrnClose();
  });
</script>
