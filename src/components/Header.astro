---
import { site } from '../data/site';

const { pathname } = Astro.url;

function isActive(path: string): boolean {
  if (path === '/') return pathname === '/';
  return pathname === path || pathname.startsWith(path + '/');
}

const navLinkClass = (path: string) =>
  isActive(path) ? 'nav-link-active' : 'nav-link';
---

<header class="bg-white border-b border-warm-200 sticky top-0 z-50">
  <div class="section-container">
    <div class="flex items-center justify-between h-16 md:h-20">

      <!-- Wordmark -->
      <a
        href="/"
        class="group flex items-center gap-2.5"
        aria-label={`${site.name} home`}
      >
        <img src="/favicon.png" alt="" width="36" height="36" class="w-8 h-8 md:w-9 md:h-9 rounded-md flex-shrink-0" />
        <span class="text-ink font-bold text-lg md:text-xl tracking-tight group-hover:text-brand-600 transition-colors">
          {site.name}
        </span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-6" aria-label="Main navigation">
        <!-- Industries dropdown -->
        <div class="relative group">
          <button
            id="industries-toggle"
            class={`${isActive('/industries') ? 'nav-link-active' : 'nav-link'} flex items-center gap-1 py-2`}
            aria-haspopup="true"
            aria-expanded="false"
            aria-controls="industries-menu"
          >
            Industries
            <svg class="w-4 h-4 mt-0.5 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div id="industries-menu" class="absolute top-full left-0 mt-1 w-64 bg-white border border-warm-200 rounded-lg shadow-lg invisible opacity-0 group-hover:visible group-hover:opacity-100 transition-all duration-150 z-50">
            <a href="/industries/precision-manufacturing" class="flex items-start gap-3 px-4 py-3.5 hover:bg-warm rounded-t-lg transition-colors group/link">
              <span class="text-ink-muted group-hover/link:text-ink transition-colors">
                <span class="block font-medium text-ink text-sm">Machine Shops &amp; Fabricators</span>
                <span class="text-xs text-ink-muted">Aerospace, defense, precision parts</span>
              </span>
            </a>
            <a href="/industries/med-spas" class="flex items-start gap-3 px-4 py-3.5 hover:bg-warm transition-colors group/link border-t border-warm-200">
              <span class="text-ink-muted group-hover/link:text-ink transition-colors">
                <span class="block font-medium text-ink text-sm">Med Spas &amp; Aesthetics</span>
                <span class="text-xs text-ink-muted">Consults, no-shows, reactivation</span>
              </span>
            </a>
            <a href="/industries/home-services" class="flex items-start gap-3 px-4 py-3.5 hover:bg-warm rounded-b-lg transition-colors group/link border-t border-warm-200">
              <span class="text-ink-muted group-hover/link:text-ink transition-colors">
                <span class="block font-medium text-ink text-sm">Contractors &amp; Home Services</span>
                <span class="text-xs text-ink-muted">HVAC, plumbing, general contractors</span>
              </span>
            </a>
          </div>
        </div>

        <a href="/websites"     class={navLinkClass('/websites')}>Websites</a>
        <a href="/how-it-works" class={navLinkClass('/how-it-works')}>How It Works</a>
        <a href="/learn"        class={navLinkClass('/learn')}>Crash Course</a>
        <a href="/about"        class={navLinkClass('/about')}>About</a>
        <a href={site.ctaHref}  class="btn-primary text-sm py-2.5 px-5 whitespace-nowrap">{site.ctaShort}</a>
      </nav>

      <!-- Mobile: CTA + hamburger -->
      <div class="flex items-center gap-3 lg:hidden">
        <a href={site.ctaHref} class="btn-primary text-sm py-2 px-4 hidden sm:inline-flex whitespace-nowrap">{site.ctaShort}</a>
        <button
          id="menu-toggle"
          class="p-2 text-ink hover:text-brand-600 transition-colors"
          aria-label="Toggle navigation menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg id="icon-open" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="icon-close" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-warm-200 bg-white" aria-label="Mobile navigation">
    <nav class="section-container py-4 flex flex-col gap-1">
      <p class="text-xs font-semibold text-ink-muted uppercase tracking-wider px-3 py-2">Industries</p>
      <a href="/industries/precision-manufacturing" class="px-3 py-2.5 text-ink-light hover:text-ink hover:bg-warm rounded transition-colors">Machine Shops &amp; Fabricators</a>
      <a href="/industries/med-spas"                class="px-3 py-2.5 text-ink-light hover:text-ink hover:bg-warm rounded transition-colors">Med Spas &amp; Aesthetics</a>
      <a href="/industries/home-services"           class="px-3 py-2.5 text-ink-light hover:text-ink hover:bg-warm rounded transition-colors">Contractors &amp; Home Services</a>
      <div class="my-1 border-t border-warm-200"></div>
      <a href="/websites"     class="px-3 py-2.5 text-ink-light hover:text-ink hover:bg-warm rounded transition-colors">Websites</a>
      <a href="/how-it-works" class="px-3 py-2.5 text-ink-light hover:text-ink hover:bg-warm rounded transition-colors">How It Works</a>
      <a href="/learn"        class="px-3 py-2.5 text-ink-light hover:text-ink hover:bg-warm rounded transition-colors">Crash Course</a>
      <a href="/about"        class="px-3 py-2.5 text-ink-light hover:text-ink hover:bg-warm rounded transition-colors">About</a>
      <div class="pt-2">
        <a href={site.ctaHref} class="btn-primary w-full justify-center">{site.ctaText}</a>
      </div>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu   = document.getElementById('mobile-menu');
  const iconOpen  = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });

  // Close on outside click
  document.addEventListener('click', (e) => {
    if (!toggle?.contains(e.target as Node) && !menu?.contains(e.target as Node)) {
      menu?.classList.add('hidden');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
    }
  });

  // Industries dropdown: keyboard + click support (hover still works via CSS)
  const indToggle = document.getElementById('industries-toggle');
  const indMenu   = document.getElementById('industries-menu');

  const indOpen  = () => { indMenu?.classList.remove('invisible', 'opacity-0'); indToggle?.setAttribute('aria-expanded', 'true'); };
  const indClose = () => { indMenu?.classList.add('invisible', 'opacity-0'); indToggle?.setAttribute('aria-expanded', 'false'); };

  indToggle?.addEventListener('click', () => {
    indMenu?.classList.contains('invisible') ? indOpen() : indClose();
  });

  document.addEventListener('keydown', (e) => {
    if ((e as KeyboardEvent).key === 'Escape') indClose();
  });

  document.addEventListener('click', (e) => {
    if (!indToggle?.contains(e.target as Node) && !indMenu?.contains(e.target as Node)) indClose();
  });
</script>
