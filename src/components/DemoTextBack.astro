---
// Live demo: missed call -> automatic text-back.
// Pure client-side. Auto-plays once on scroll-in, plus a Replay button.
---

<div class="demo-textback bg-warm-100 border border-warm-200 rounded-lg p-6 md:p-8" aria-hidden="true">
  <div class="flex items-center justify-between mb-4">
    <p class="text-xs font-semibold uppercase tracking-wider text-ink-muted">What the customer sees</p>
    <button type="button" class="demo-replay inline-flex items-center gap-1.5 text-xs font-semibold text-brand-600 hover:text-brand-700 transition-colors" aria-label="Replay the text-back demo">
      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992V4.356M2.985 19.644v-4.992h4.992m-5.073-2.876a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" />
      </svg>
      Replay
    </button>
  </div>

  <div class="demo-stage space-y-3 min-h-[180px]">
    <!-- 1. Missed call (customer side, right) -->
    <div class="demo-line demo-line-1 flex justify-end">
      <div class="bg-ink-muted/10 text-ink-light text-sm rounded-2xl rounded-tr-sm px-4 py-2.5 max-w-[78%] inline-flex items-center gap-2">
        <svg class="w-4 h-4 text-ink-muted flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 3.75l4.5 4.5m0-4.5l-4.5 4.5M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
        </svg>
        Missed call (no voicemail)
      </div>
    </div>

    <!-- 2. Typing indicator (business side, left) -->
    <div class="demo-typing flex justify-start">
      <div class="bg-brand-600 rounded-2xl rounded-tl-sm px-4 py-3 inline-flex items-center gap-1.5">
        <span class="demo-dot"></span>
        <span class="demo-dot"></span>
        <span class="demo-dot"></span>
      </div>
    </div>

    <!-- 3. Auto text-back (business side, left) -->
    <div class="demo-line demo-line-3 flex justify-start">
      <div class="bg-brand-600 text-white text-sm rounded-2xl rounded-tl-sm px-4 py-2.5 max-w-[85%]">
        Hi, this is <span data-biz>[Business Name]</span>. Sorry we missed you. What can we help you with?
      </div>
    </div>

    <!-- 4. Sent stamp -->
    <p class="demo-line demo-line-4 text-xs text-ink-muted text-center pt-1 flex items-center justify-center gap-1.5">
      <svg class="w-3.5 h-3.5 text-green-600" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
      </svg>
      Sent automatically in 47 seconds
    </p>
  </div>
</div>

<style>
  /* Hidden steps before play */
  .demo-line { opacity: 0; transform: translateY(8px); }
  .demo-typing { opacity: 0; }

  /* Played state (added per-step by JS) */
  .demo-line.is-on { animation: lineIn 0.45s ease forwards; }
  .demo-typing.is-on { opacity: 1; }
  .demo-typing.is-off { display: none; }

  @keyframes lineIn { to { opacity: 1; transform: translateY(0); } }

  .demo-dot {
    width: 6px; height: 6px; border-radius: 9999px;
    background: rgba(255, 255, 255, 0.85);
    display: inline-block;
    animation: dotPulse 1.1s ease-in-out infinite;
  }
  .demo-dot:nth-child(2) { animation-delay: 0.18s; }
  .demo-dot:nth-child(3) { animation-delay: 0.36s; }
  @keyframes dotPulse {
    0%, 60%, 100% { opacity: 0.3; transform: translateY(0); }
    30% { opacity: 1; transform: translateY(-3px); }
  }

  /* Reduced motion: show everything, no animation */
  @media (prefers-reduced-motion: reduce) {
    .demo-line { opacity: 1; transform: none; animation: none; }
    .demo-typing { display: none; }
    .demo-dot { animation: none; }
  }
</style>

<script>
  (() => {
    document.querySelectorAll<HTMLElement>('.demo-textback').forEach((demo) => {
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const lines = demo.querySelectorAll<HTMLElement>('.demo-line');
      const typing = demo.querySelector<HTMLElement>('.demo-typing');
      const replay = demo.querySelector<HTMLButtonElement>('.demo-replay');
      let timers: number[] = [];

      const clear = () => { timers.forEach((t) => clearTimeout(t)); timers = []; };

      const reset = () => {
        clear();
        lines.forEach((l) => l.classList.remove('is-on'));
        typing?.classList.remove('is-on', 'is-off');
      };

      const play = () => {
        if (reduce) { lines.forEach((l) => l.classList.add('is-on')); return; }
        reset();
        const line1 = demo.querySelector<HTMLElement>('.demo-line-1');
        const line3 = demo.querySelector<HTMLElement>('.demo-line-3');
        const line4 = demo.querySelector<HTMLElement>('.demo-line-4');
        timers.push(window.setTimeout(() => line1?.classList.add('is-on'), 300));
        timers.push(window.setTimeout(() => typing?.classList.add('is-on'), 1100));
        timers.push(window.setTimeout(() => {
          typing?.classList.remove('is-on');
          typing?.classList.add('is-off');
          line3?.classList.add('is-on');
        }, 2400));
        timers.push(window.setTimeout(() => line4?.classList.add('is-on'), 3100));
      };

      replay?.addEventListener('click', play);

      // Auto-play once when scrolled into view
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => { if (e.isIntersecting) { play(); io.unobserve(e.target); } });
      }, { threshold: 0.4 });
      io.observe(demo);
    });
  })();
</script>
