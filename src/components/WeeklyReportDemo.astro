---
// Live demo: the Weekly Report email rendering line by line in a stylized
// email client. Same mechanism as DemoTextBack: auto-plays once on scroll-in,
// Replay button, reduced-motion shows the final state. Pure client-side.
---

<div class="demo-weekly bg-warm-100 border border-warm-200 rounded-lg p-4 sm:p-6 md:p-8" aria-hidden="true">
  <div class="flex items-center justify-between mb-4">
    <p class="text-xs font-semibold uppercase tracking-wider text-ink-muted">What lands in your inbox</p>
    <button type="button" class="demo-replay inline-flex items-center gap-1.5 text-xs font-semibold text-brand-600 hover:text-brand-700 transition-colors" aria-label="Replay the Weekly Report demo">
      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992V4.356M2.985 19.644v-4.992h4.992m-5.073-2.876a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" />
      </svg>
      Replay
    </button>
  </div>

  <!-- Email client frame -->
  <div class="bg-white border border-warm-200 rounded-lg overflow-hidden shadow-sm">
    <!-- Window bar -->
    <div class="flex items-center gap-2 px-4 py-2.5 bg-warm-50 border-b border-warm-200">
      <span class="w-2.5 h-2.5 rounded-full bg-warm-200" aria-hidden="true"></span>
      <span class="w-2.5 h-2.5 rounded-full bg-warm-200" aria-hidden="true"></span>
      <span class="w-2.5 h-2.5 rounded-full bg-warm-200" aria-hidden="true"></span>
      <span class="ml-2 text-xs text-ink-muted font-medium">Inbox, Monday 6:02 AM</span>
    </div>

    <!-- Email header -->
    <div class="wr-line wr-line-1 px-4 sm:px-5 py-3 border-b border-warm-100">
      <p class="text-xs text-ink-muted mb-1">From: <span class="text-ink font-medium">The Weekly Report</span></p>
      <p class="text-sm font-bold text-ink leading-snug">Your Weekly Report: Week of <span data-wr-date>June 15</span></p>
    </div>

    <!-- Email body -->
    <div class="px-4 sm:px-5 py-4 space-y-3">

      <div class="wr-line wr-line-2 flex items-start gap-2.5">
        <span class="w-5 h-5 rounded-full bg-green-50 flex items-center justify-center flex-shrink-0 mt-0.5">
          <svg class="w-3 h-3 text-green-600" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941" />
          </svg>
        </span>
        <p class="text-sm text-ink leading-snug">Revenue last week: <strong class="font-semibold">$84,200</strong> <span class="text-green-700 font-medium">(&uarr; 6% vs 4-week avg)</span></p>
      </div>

      <div class="wr-line wr-line-3 flex items-start gap-2.5">
        <span class="w-5 h-5 rounded-full bg-amber-50 flex items-center justify-center flex-shrink-0 mt-0.5">
          <svg class="w-3 h-3 text-amber-600" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m0 3h.008v.008H12v-.008z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3l9 16.5H3L12 3z" />
          </svg>
        </span>
        <p class="text-sm text-ink leading-snug"><strong class="font-semibold">$23,400</strong> in invoices past 30 days. 3 clients, <span class="text-brand-600 font-medium">drafted reminders ready</span></p>
      </div>

      <div class="wr-line wr-line-4 flex items-start gap-2.5">
        <span class="w-5 h-5 rounded-full bg-amber-50 flex items-center justify-center flex-shrink-0 mt-0.5">
          <svg class="w-3 h-3 text-amber-600" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </span>
        <p class="text-sm text-ink leading-snug"><strong class="font-semibold">6 leads went cold.</strong> Avg response time slipped to 9 hours</p>
      </div>

      <div class="wr-line wr-line-5 bg-brand-50 border border-brand-100 rounded-lg p-3.5">
        <p class="text-xs font-bold uppercase tracking-wider text-brand-600 mb-1.5">This week's move</p>
        <p class="text-sm text-ink leading-relaxed">Reactivate the 14 quotes sent 30–60 days ago that never closed. Historical close rate on reactivation: 12%. <strong class="font-semibold">Estimated value: $18,000.</strong></p>
      </div>

    </div>
  </div>

  <p class="text-xs text-ink-muted text-center mt-3">A sample report. Your numbers, from your systems, every Monday at 6am.</p>
</div>

<style>
  .wr-line { opacity: 0; transform: translateY(8px); }
  .wr-line.is-on { animation: wrIn 0.45s ease forwards; }
  @keyframes wrIn { to { opacity: 1; transform: translateY(0); } }

  @media (prefers-reduced-motion: reduce) {
    .wr-line { opacity: 1; transform: none; animation: none; }
  }
</style>

<script>
  (() => {
    document.querySelectorAll<HTMLElement>('.demo-weekly').forEach((demo) => {
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const lines = demo.querySelectorAll<HTMLElement>('.wr-line');
      const replay = demo.querySelector<HTMLButtonElement>('.demo-replay');
      let timers: number[] = [];

      // Always-current subject date: the most recent Monday
      const d = new Date();
      d.setDate(d.getDate() - ((d.getDay() + 6) % 7));
      const label = d.toLocaleDateString('en-US', { month: 'long', day: 'numeric' });
      demo.querySelectorAll('[data-wr-date]').forEach((el) => { el.textContent = label; });

      const clear = () => { timers.forEach((t) => clearTimeout(t)); timers = []; };
      const reset = () => { clear(); lines.forEach((l) => l.classList.remove('is-on')); };

      const play = () => {
        if (reduce) { lines.forEach((l) => l.classList.add('is-on')); return; }
        reset();
        const delays = [300, 1000, 1700, 2400, 3200];
        lines.forEach((line, i) => {
          timers.push(window.setTimeout(() => line.classList.add('is-on'), delays[i] ?? 3200));
        });
      };

      replay?.addEventListener('click', play);

      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => { if (e.isIntersecting) { play(); io.unobserve(e.target); } });
      }, { threshold: 0.3 });
      io.observe(demo);
    });
  })();
</script>
