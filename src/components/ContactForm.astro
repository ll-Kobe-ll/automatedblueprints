---
import { site } from '../data/site';
---

<form
  id="contact-form"
  class="space-y-6"
  novalidate
  aria-label="Contact form"
>
  <!-- Honeypot -->
  <input
    type="text"
    name="botcheck"
    class="sr-only"
    tabindex="-1"
    autocomplete="off"
    aria-hidden="true"
  />

  <!-- Set from ?about= query param so the inbox email is tagged by product -->
  <input type="hidden" id="cf-about" name="about" value="" />

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
    <div>
      <label for="cf-name" class="block text-sm font-semibold text-ink mb-1.5">
        Your Name <span class="text-brand-600" aria-hidden="true">*</span><span class="sr-only">(required)</span>
      </label>
      <input
        type="text"
        id="cf-name"
        name="name"
        autocomplete="name"
        placeholder="Jane Smith"
        required
        class="w-full border border-warm-200 rounded px-4 py-3 text-ink placeholder-ink-muted bg-white focus:outline-none focus:ring-2 focus:ring-brand-600 focus:border-transparent transition"
      />
    </div>

    <div>
      <label for="cf-business" class="block text-sm font-semibold text-ink mb-1.5">
        Business Name <span class="text-brand-600" aria-hidden="true">*</span><span class="sr-only">(required)</span>
      </label>
      <input
        type="text"
        id="cf-business"
        name="business"
        autocomplete="organization"
        placeholder="Smith HVAC"
        required
        class="w-full border border-warm-200 rounded px-4 py-3 text-ink placeholder-ink-muted bg-white focus:outline-none focus:ring-2 focus:ring-brand-600 focus:border-transparent transition"
      />
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
    <div>
      <label for="cf-email" class="block text-sm font-semibold text-ink mb-1.5">
        Email <span class="text-brand-600" aria-hidden="true">*</span><span class="sr-only">(required)</span>
      </label>
      <input
        type="email"
        id="cf-email"
        name="email"
        autocomplete="email"
        placeholder="jane@smithhvac.com"
        required
        class="w-full border border-warm-200 rounded px-4 py-3 text-ink placeholder-ink-muted bg-white focus:outline-none focus:ring-2 focus:ring-brand-600 focus:border-transparent transition"
      />
    </div>

    <div>
      <label for="cf-website" class="block text-sm font-semibold text-ink mb-1.5">
        Website URL <span class="text-ink-muted font-normal">(optional)</span>
      </label>
      <input
        type="url"
        id="cf-website"
        name="website"
        autocomplete="url"
        placeholder="https://smithhvac.com"
        class="w-full border border-warm-200 rounded px-4 py-3 text-ink placeholder-ink-muted bg-white focus:outline-none focus:ring-2 focus:ring-brand-600 focus:border-transparent transition"
      />
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
    <div>
      <label for="cf-has-website" class="block text-sm font-semibold text-ink mb-1.5">
        Do you have a website? <span class="text-ink-muted font-normal">(optional)</span>
      </label>
      <select
        id="cf-has-website"
        name="has_website"
        class="w-full border border-warm-200 rounded px-4 py-3 text-ink bg-white focus:outline-none focus:ring-2 focus:ring-brand-600 focus:border-transparent transition"
      >
        <option value="">Select one</option>
        <option value="Yes">Yes</option>
        <option value="No">No</option>
        <option value="Just a Facebook or social page">Just a Facebook or social page</option>
      </select>
    </div>

    <div>
      <label for="cf-budget" class="block text-sm font-semibold text-ink mb-1.5">
        Monthly budget <span class="text-ink-muted font-normal">(optional)</span>
      </label>
      <select
        id="cf-budget"
        name="budget"
        class="w-full border border-warm-200 rounded px-4 py-3 text-ink bg-white focus:outline-none focus:ring-2 focus:ring-brand-600 focus:border-transparent transition"
      >
        <option value="">Select one</option>
        <option value="Not sure yet">Not sure yet</option>
        <option value="Under $500/mo">Under $500/mo</option>
        <option value="$500 to $1,000/mo">$500 to $1,000/mo</option>
        <option value="$1,000 to $2,500/mo">$1,000 to $2,500/mo</option>
        <option value="$2,500+/mo">$2,500+/mo</option>
      </select>
    </div>
  </div>

  <div>
    <label for="cf-crm" class="block text-sm font-semibold text-ink mb-1.5">
      What do you use to manage leads now? <span class="text-ink-muted font-normal">(optional)</span>
    </label>
    <input
      type="text"
      id="cf-crm"
      name="crm"
      placeholder="Spreadsheet, Jobber, nothing yet..."
      class="w-full border border-warm-200 rounded px-4 py-3 text-ink placeholder-ink-muted bg-white focus:outline-none focus:ring-2 focus:ring-brand-600 focus:border-transparent transition"
    />
  </div>

  <div>
    <label for="cf-message" class="block text-sm font-semibold text-ink mb-1.5">
      What's the main thing costing you jobs? <span class="text-ink-muted font-normal">(optional)</span>
    </label>
    <textarea
      id="cf-message"
      name="message"
      rows="4"
      placeholder="Missed calls, slow follow-up, no website, whatever it is..."
      class="w-full border border-warm-200 rounded px-4 py-3 text-ink placeholder-ink-muted bg-white focus:outline-none focus:ring-2 focus:ring-brand-600 focus:border-transparent transition resize-y"
    ></textarea>
  </div>

  <div>
    <button
      type="submit"
      id="cf-submit"
      class="btn-primary-lg w-full sm:w-auto"
    >
      Send Message
    </button>
  </div>

  <div
    id="cf-status"
    role="status"
    aria-live="polite"
    class="text-sm font-medium min-h-[1.5rem]"
  ></div>
</form>

<script define:vars={{ web3key: site.web3formsKey }}>
  const form     = document.getElementById('contact-form');
  const statusEl = document.getElementById('cf-status');
  const submitBtn = document.getElementById('cf-submit');

  // Tag the submission by product when arriving from a product CTA
  const aboutParam = new URLSearchParams(window.location.search).get('about') ?? '';
  const aboutEl = document.getElementById('cf-about');
  if (aboutEl) aboutEl.value = aboutParam;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Honeypot check
    const honeypot = form.querySelector('[name="botcheck"]');
    if (honeypot?.value) return;

    // Basic validation
    const required = ['cf-name', 'cf-business', 'cf-email'];
    let valid = true;
    for (const id of required) {
      const el = document.getElementById(id);
      if (!el?.value.trim()) {
        el?.focus();
        setStatus('Please fill in all required fields.', 'error');
        valid = false;
        break;
      }
    }
    if (!valid) return;

    const emailEl = document.getElementById('cf-email');
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailEl?.value ?? '')) {
      emailEl?.focus();
      setStatus('Please enter a valid email address.', 'error');
      return;
    }

    setStatus('', '');
    const defaultLabel = submitBtn?.textContent ?? 'Send Message';
    if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Sending...'; }

    const about = document.getElementById('cf-about')?.value ?? '';
    const payload = {
      access_key: web3key,
      subject:
        about === 'weekly-report'      ? 'Weekly Report: Free Trial Request' :
        about === 'website'            ? 'New Inquiry: The Website' :
        about === 'lead-flow-system'   ? 'New Inquiry: The Lead Flow System' :
        about === 'growth-partner'     ? 'New Inquiry: Growth Partner' :
        'New Contact Inquiry: Automated Blueprints',
      about,
      from_name:    document.getElementById('cf-name')?.value ?? '',
      email:        document.getElementById('cf-email')?.value ?? '',
      business:     document.getElementById('cf-business')?.value ?? '',
      website:      document.getElementById('cf-website')?.value ?? '',
      has_website:  document.getElementById('cf-has-website')?.value ?? '',
      budget:       document.getElementById('cf-budget')?.value ?? '',
      manages_leads_with: document.getElementById('cf-crm')?.value ?? '',
      message:      document.getElementById('cf-message')?.value ?? '',
      redirect:     'false',
      botcheck:     '',
    };

    try {
      const res  = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = await res.json();

      if (data.success) {
        form.reset();
        if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = defaultLabel; }
        setStatus('Done. Expect a response within minutes.', 'ok');
      } else {
        throw new Error(data.message ?? 'Submission failed');
      }
    } catch {
      if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = ctaText; }
      setStatus('Something went wrong. Email us directly at ' + (document.querySelector('[href^="mailto:"]')?.textContent ?? ''), 'error');
    }
  });

  function setStatus(msg, type) {
    if (!statusEl) return;
    statusEl.textContent = msg;
    statusEl.className = 'text-sm font-medium min-h-[1.5rem] ' +
      (type === 'ok' ? 'text-green-700' : type === 'error' ? 'text-red-600' : '');
  }
</script>
