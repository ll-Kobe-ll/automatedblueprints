---
import { site } from '../data/site';

const year = new Date().getFullYear();
---

<footer class="bg-ink text-white">
  <div class="section-container py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-8 pb-12 border-b border-white/10">

      <!-- Brand column -->
      <div class="md:col-span-1">
        <div class="flex items-center gap-2.5 mb-3">
          <img src="/favicon.png" alt="" width="36" height="36" loading="lazy" class="w-9 h-9 rounded-md flex-shrink-0" />
          <p class="text-white font-bold text-xl tracking-tight">{site.name}</p>
        </div>
        <p class="text-white/60 text-sm leading-relaxed mb-4">{site.tagline}</p>
        <p class="text-white/50 text-sm">Based in {site.location}.</p>
      </div>

      <!-- Pages -->
      <div>
        <p class="text-white/50 text-xs font-semibold uppercase tracking-wider mb-4">Pages</p>
        <nav aria-label="Footer navigation">
          <ul class="space-y-2.5">
            <li><a href="/"              class="text-white/70 hover:text-white transition-colors text-sm">Home</a></li>
            <li><a href="/audit"         class="text-white/70 hover:text-white transition-colors text-sm">Free Lead Audit</a></li>
            <li><a href="/websites"      class="text-white/70 hover:text-white transition-colors text-sm">Plans &amp; Pricing</a></li>
            <li><a href="/how-it-works"  class="text-white/70 hover:text-white transition-colors text-sm">How It Works</a></li>
            <li><a href="/templates"     class="text-white/70 hover:text-white transition-colors text-sm">Templates</a></li>
            <li><a href="/blog"          class="text-white/70 hover:text-white transition-colors text-sm">Blog</a></li>
            <li><a href="/learn"         class="text-white/70 hover:text-white transition-colors text-sm">Crash Course</a></li>
            <li><a href="/about"         class="text-white/70 hover:text-white transition-colors text-sm">About</a></li>
            <li><a href="/contact"       class="text-white/70 hover:text-white transition-colors text-sm">Contact</a></li>
          </ul>
        </nav>
      </div>

      <!-- Industries + Contact -->
      <div>
        <p class="text-white/50 text-xs font-semibold uppercase tracking-wider mb-4">Industries</p>
        <nav aria-label="Industry pages" class="mb-8">
          <ul class="space-y-2.5">
            <li><a href="/industries/precision-manufacturing" class="text-white/70 hover:text-white transition-colors text-sm">Machine Shops &amp; Fabricators</a></li>
            <li><a href="/industries/med-spas"                class="text-white/70 hover:text-white transition-colors text-sm">Med Spas &amp; Aesthetics</a></li>
            <li><a href="/industries/home-services"           class="text-white/70 hover:text-white transition-colors text-sm">Contractors &amp; Home Services</a></li>
          </ul>
        </nav>

        <p class="text-white/50 text-xs font-semibold uppercase tracking-wider mb-4">Contact</p>
        <ul class="space-y-2.5">
          <li>
            <a href={`mailto:${site.email}`} class="text-white/70 hover:text-white transition-colors text-sm">
              {site.email}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <p class="text-white/40 text-sm">
        &copy; {year} {site.name}. All rights reserved.
      </p>
      <div class="flex items-center gap-5">
        <a href="/privacy" class="text-white/40 hover:text-white/70 transition-colors text-sm">Privacy</a>
        <a href="/terms"   class="text-white/40 hover:text-white/70 transition-colors text-sm">Terms</a>
        <p class="text-white/40 text-sm">Based in {site.location}</p>
      </div>
    </div>
  </div>
</footer>
