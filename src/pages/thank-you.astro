---
import BaseLayout from '../layouts/BaseLayout.astro';
import { license } from '../data/templateKit';
import { site } from '../data/site';

const title       = 'Thank You | Your Download Is Ready | Automated Blueprints';
const description = 'Your template purchase is confirmed. Download your files and get building.';
---

<BaseLayout {title} {description} canonicalPath="/thank-you" noIndex={true} bare={true}>

  <section class="bg-warm-50 min-h-[calc(100vh-4rem)] py-12 md:py-20" aria-label="Purchase confirmation">
    <div class="section-container max-w-2xl">

      <!-- Loading -->
      <div id="state-loading" class="text-center py-16">
        <div class="w-12 h-12 rounded-full border-4 border-warm-200 border-t-brand-600 animate-spin mx-auto mb-6" aria-hidden="true"></div>
        <p class="text-ink-light text-lg">Confirming your purchase…</p>
      </div>

      <!-- Success -->
      <div id="state-success" class="hidden">
        <div class="text-center mb-8">
          <div class="w-16 h-16 rounded-full bg-green-50 flex items-center justify-center mx-auto mb-5">
            <svg class="w-8 h-8 text-green-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <h1 class="text-3xl md:text-4xl font-bold text-ink tracking-tight mb-3">You Are In.</h1>
          <p class="text-ink-light text-lg" id="success-product-line">Your purchase is confirmed.</p>
        </div>

        <div class="bg-white border border-warm-200 rounded-xl shadow-sm p-6 md:p-8 mb-6 text-center">
          <a id="download-btn" href="#" class="btn-primary-lg w-full justify-center group">
            <svg class="w-5 h-5 mr-2 group-hover:translate-y-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
            </svg>
            <span id="download-label">Download Your Template</span>
          </a>
          <p class="text-ink-muted text-xs mt-4">One zip, everything inside. Save it somewhere safe. This link works for 30 days.</p>
        </div>

        <div class="bg-white border border-warm-200 rounded-xl p-6 md:p-8 mb-6">
          <h2 class="font-bold text-ink mb-4">Three commands to a running site</h2>
          <ol class="space-y-2.5 mb-5">
            <li class="flex items-start gap-3 text-ink-light text-sm leading-relaxed">
              <span class="w-5 h-5 rounded-full bg-brand-600 text-white text-xs font-bold flex items-center justify-center flex-shrink-0 mt-0.5">1</span>
              <span>Unzip the file somewhere simple, like <code class="bg-warm-100 px-1.5 py-0.5 rounded text-xs">C:\dev\</code> or your home folder.</span>
            </li>
            <li class="flex items-start gap-3 text-ink-light text-sm leading-relaxed">
              <span class="w-5 h-5 rounded-full bg-brand-600 text-white text-xs font-bold flex items-center justify-center flex-shrink-0 mt-0.5">2</span>
              <span>Open a terminal in that folder and run <code class="bg-warm-100 px-1.5 py-0.5 rounded text-xs">npm install</code>.</span>
            </li>
            <li class="flex items-start gap-3 text-ink-light text-sm leading-relaxed">
              <span class="w-5 h-5 rounded-full bg-brand-600 text-white text-xs font-bold flex items-center justify-center flex-shrink-0 mt-0.5">3</span>
              <span>Follow the README in the zip. It covers dev, customizing the config, and deploying free.</span>
            </li>
          </ol>
          <p class="text-ink-muted text-sm">The zip also includes the deploy guide, the reseller guide, and an AI setup prompt that customizes the whole site fast.</p>
        </div>

        <div class="bg-warm-100 border border-warm-200 rounded-xl p-6 md:p-8">
          <h2 class="font-bold text-ink mb-4">Your license, in plain English</h2>
          <ul class="space-y-2.5">
            {license.map(item => (
              <li class="flex items-start gap-3 text-ink-light text-sm leading-relaxed">
                <svg class="w-5 h-5 text-brand-600 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
          <p class="text-ink-muted text-sm mt-5">The full license is in the zip. One thing you cannot do: resell or give away the template files themselves. Digital sales are final, but if anything in your download is broken, email us and we will make it right.</p>
        </div>

        <p class="text-ink-muted text-sm text-center mt-8">
          Lost the file or hit a problem? Email <a href={`mailto:${site.email}`} class="text-brand-600 font-semibold hover:text-brand-700 transition-colors">{site.email}</a> with your receipt and we will sort it out.
        </p>
      </div>

      <!-- Error -->
      <div id="state-error" class="hidden text-center py-16">
        <div class="w-16 h-16 rounded-full bg-amber-50 flex items-center justify-center mx-auto mb-5">
          <svg class="w-8 h-8 text-amber-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h1 class="text-3xl font-bold text-ink tracking-tight mb-3">We Could Not Confirm That Automatically</h1>
        <p id="error-message" class="text-ink-light text-lg max-w-md mx-auto mb-8">Something went wrong loading your purchase.</p>
        <a href={`mailto:${site.email}?subject=${encodeURIComponent('Template purchase: send my files')}`} class="btn-primary-lg">
          Email Us Your Receipt
        </a>
        <p class="text-ink-muted text-sm mt-4">We will send your files directly, usually within a few hours.</p>
      </div>

    </div>
  </section>

</BaseLayout>

<script>
  (async () => {
    const show = (id: string) => {
      ['state-loading', 'state-success', 'state-error'].forEach((s) =>
        document.getElementById(s)?.classList.toggle('hidden', s !== id)
      );
    };

    const sessionId = new URLSearchParams(window.location.search).get('session_id');
    const errEl = document.getElementById('error-message');

    if (!sessionId) {
      if (errEl) errEl.textContent = 'This page only works right after checkout. Use the link from your receipt, or email us and we will send your files.';
      show('state-error');
      return;
    }

    try {
      const res = await fetch(`/api/download?session_id=${encodeURIComponent(sessionId)}&action=info`);
      const data = await res.json();

      if (!res.ok) {
        if (errEl && data.message) errEl.textContent = data.message;
        show('state-error');
        return;
      }

      const line = document.getElementById('success-product-line');
      if (line) line.textContent = `${data.name} is paid for and ready.`;
      const label = document.getElementById('download-label');
      if (label) label.textContent = `Download: ${data.name}`;
      const btn = document.getElementById('download-btn') as HTMLAnchorElement | null;
      if (btn) btn.href = `/api/download?session_id=${encodeURIComponent(sessionId)}&action=file`;
      show('state-success');
    } catch {
      if (errEl) errEl.textContent = 'We could not reach the delivery service. Email us your receipt and we will send the files directly.';
      show('state-error');
    }
  })();
</script>
