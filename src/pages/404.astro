---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';

const title       = 'Page Not Found | Automated Blueprints';
const description = 'That page does not exist. Head back home or get in touch.';
---

<BaseLayout {title} {description} canonicalPath="/404" noIndex={true}>

  <section class="bg-ink text-white" aria-label="Page not found">
    <div class="section-container py-28 md:py-36 text-center">
      <p class="text-brand-300 text-sm font-semibold uppercase tracking-wider mb-5">Error 404</p>
      <h1 class="text-white text-4xl md:text-6xl font-bold tracking-tight leading-tight mb-6">
        This Page Went Missing.
      </h1>
      <p class="text-white/75 text-xl leading-relaxed max-w-xl mx-auto mb-10">
        The link is broken or the page moved. No leads were harmed. Let us get you back on track.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="btn-primary-lg bg-white !text-brand-700 hover:bg-brand-50 focus-visible:outline-white">
          Back to Home
        </a>
        <a href={site.ctaHref} class="btn-ghost-lg border-white/30 text-white hover:bg-white/10 hover:border-white/50">
          Get in Touch
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
