---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaSection from '../components/CtaSection.astro';
import DemoTextBack from '../components/DemoTextBack.astro';
import DemoFollowUp from '../components/DemoFollowUp.astro';
import DemoReviews from '../components/DemoReviews.astro';
import PricingCards from '../components/PricingCards.astro';
import { site } from '../data/site';

const title       = 'How the Lead Flow System Works | Automated Blueprints';
const description = 'Four parts, one system: a website that gets you found, missed call text-back in under 60 seconds, automatic follow-up, and review generation. Here is exactly how the Lead Flow System works and what the first 30 days look like.';

// One source of truth: rendered in the FAQ section AND emitted as FAQPage schema.
const faqs = [
  {
    q: 'I already have a website. Do I have to replace it?',
    a: 'No. If your site works, the capture side of the system plugs into it and every lead it brings in gets caught. If it is old or weak, we rebuild it as part of the setup so the whole flow runs on one foundation.',
  },
  {
    q: 'Will this break my current system or workflow?',
    a: 'No. The Lead Flow System runs alongside your existing setup. Your office manager still uses the same tools and your estimating or job management software is untouched. We handle how leads find you, how they get answered, and how they get followed up.',
  },
  {
    q: 'Do I have to learn new software?',
    a: 'No. You get one simple inbox app on your phone to see conversations. We build everything else and run it.',
  },
  {
    q: 'Am I locked into a contract?',
    a: 'No. Every agreement includes a 90-day out clause. If it is not working, you can leave.',
  },
  {
    q: 'How long does setup take?',
    a: 'About a week from kickoff to going live. A new website build can add a few days, and we tell you the exact timeline up front.',
  },
  {
    q: 'What if I already have something like this?',
    a: 'Then let us look at whether it is actually working. Most setups we see have gaps costing jobs every week. A free lead audit is enough to tell.',
  },
  {
    q: 'Do I keep my phone number?',
    a: 'Yes. You keep your number. Calls forward instantly. Automated texts go out on a dedicated local number with your area code.',
  },
  {
    q: 'What happens after the first 30 days?',
    a: 'A monthly retainer covers hosting, ongoing monitoring, message tuning, and any adjustments. If something is not converting, we fix it. Most clients see the system pay for itself within the first month.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(({ q, a }) => ({
    '@type': 'Question',
    name: q,
    acceptedAnswer: { '@type': 'Answer', text: a },
  })),
};
---

<BaseLayout {title} {description} canonicalPath="/how-it-works" schema={faqSchema}>

  <!-- Page hero -->
  <section class="bg-ink text-white section-pad" aria-label="Page hero">
    <div class="section-container">
      <p class="text-brand-300 text-sm font-semibold uppercase tracking-wider mb-4">The System</p>
      <h1 class="text-white text-4xl md:text-5xl font-bold tracking-tight leading-tight max-w-3xl mb-6">
        How the Lead Flow System Works
      </h1>
      <p class="text-white/75 text-xl leading-relaxed max-w-2xl">
        A website that gets you found, and a capture engine that answers every lead, follows up, and stacks your reviews. Installed in about a week, running while you do the work.
      </p>
    </div>
  </section>

  <!-- The 4 parts -->
  <section class="section-pad bg-white" aria-labelledby="components-heading">
    <div class="section-container">
      <h2 id="components-heading" class="section-heading mb-4">Four Parts, One System</h2>
      <p class="section-sub max-w-2xl mb-8">
        The site brings the leads in. The next three make sure none of them slip away. Each one is live below, watch it run or make it yours.
      </p>

      <!-- Personalization bar: live-updates every demo message -->
      <div class="bg-brand-50 border border-brand-100 rounded-xl p-5 md:p-6 mb-16 flex flex-col sm:flex-row sm:items-center gap-4">
        <div class="flex-shrink-0">
          <label for="demo-biz-input" class="block text-sm font-semibold text-ink mb-1">See your real messages</label>
          <p class="text-xs text-ink-muted">Type your business name and the demos update live.</p>
        </div>
        <div class="sm:ml-auto w-full sm:w-72">
          <input
            id="demo-biz-input"
            type="text"
            autocomplete="organization"
            placeholder="Type your business name…"
            maxlength="40"
            class="w-full border border-warm-200 rounded-lg px-4 py-2.5 text-ink placeholder-ink-muted bg-white focus:outline-none focus:ring-2 focus:ring-brand-600 focus:border-transparent transition"
          />
        </div>
      </div>

      <!-- Part 1: the website -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-20 items-start mb-20 pb-20 border-b border-warm-200">
        <div>
          <div class="flex items-center gap-4 mb-6">
            <span class="flex-shrink-0 w-12 h-12 rounded-full bg-brand-600 text-white font-bold text-xl flex items-center justify-center" aria-hidden="true">1</span>
            <h3 class="text-2xl font-bold text-ink">A Website That Gets You Found</h3>
          </div>
          <p class="text-ink-light leading-relaxed mb-4">
            Every lead starts the same way: someone searches for what you do. If nothing real comes up, the job goes to whoever does show up. The system starts with a fast site built to rank for your trade and your area.
          </p>
          <p class="text-ink-light leading-relaxed mb-4">
            Already have a site that works? The rest of the system plugs straight into it. If it is old or weak, we rebuild it as part of the setup, on the same stack behind our <a href="/pricing" class="text-brand-600 font-semibold hover:text-brand-700 transition-colors">live builds</a>.
          </p>
          <p class="text-ink-light leading-relaxed">
            The point is not a pretty brochure. It is a front door wired directly into the three parts below, so every visitor it earns gets caught.
          </p>
        </div>
        <div class="bg-warm-100 border border-warm-200 rounded-lg p-6 md:p-8" aria-hidden="true">
          <p class="text-xs font-semibold uppercase tracking-wider text-ink-muted mb-4">What the customer sees on Google</p>
          <div class="bg-white border border-warm-200 rounded-lg p-4 mb-3">
            <div class="flex items-center gap-2 border border-warm-200 rounded-full px-4 py-2 mb-4">
              <svg class="w-4 h-4 text-ink-muted flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
              </svg>
              <span class="text-sm text-ink">plumber near me</span>
            </div>
            <div class="border-l-2 border-brand-600 pl-3 py-1 mb-3">
              <p class="text-brand-600 text-sm font-semibold"><span data-biz>[Business Name]</span> | Licensed &amp; Insured</p>
              <p class="text-xs text-ink-muted">Fast response. 120+ five-star reviews. Free estimates.</p>
            </div>
            <div class="opacity-40 pl-3 mb-2">
              <p class="text-ink text-sm">Some Other Company</p>
              <p class="text-xs text-ink-muted">No website. 4 reviews.</p>
            </div>
            <div class="opacity-25 pl-3">
              <p class="text-ink text-sm">Another Competitor</p>
              <p class="text-xs text-ink-muted">Site last updated 2019.</p>
            </div>
          </div>
          <p class="text-xs text-ink-muted text-center">First to show up, first to get the call</p>
        </div>
      </div>

      <!-- Part 2 -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-20 items-start mb-20 pb-20 border-b border-warm-200">
        <div>
          <div class="flex items-center gap-4 mb-6">
            <span class="flex-shrink-0 w-12 h-12 rounded-full bg-brand-600 text-white font-bold text-xl flex items-center justify-center" aria-hidden="true">2</span>
            <h3 class="text-2xl font-bold text-ink">Missed Call Text-Back</h3>
          </div>
          <p class="text-ink-light leading-relaxed mb-4">
            Any call you cannot answer gets a text response in under 60 seconds. It goes out on a local number that matches your area code, so it looks like a real person from your business.
          </p>
          <p class="text-ink-light leading-relaxed mb-4">
            The message is short and direct: lets the caller know you received their call and asks what they need. Most people reply. The conversation is already started before they pick up the phone to try a competitor.
          </p>
          <p class="text-ink-light leading-relaxed">
            You see the conversation in a single inbox on your phone. When you are ready to call back, the context is right there.
          </p>
        </div>
        <DemoTextBack />
      </div>

      <!-- Part 3 -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-20 items-start mb-20 pb-20 border-b border-warm-200">
        <div>
          <div class="flex items-center gap-4 mb-6">
            <span class="flex-shrink-0 w-12 h-12 rounded-full bg-brand-600 text-white font-bold text-xl flex items-center justify-center" aria-hidden="true">3</span>
            <h3 class="text-2xl font-bold text-ink">Lead &amp; Quote Follow-Up</h3>
          </div>
          <p class="text-ink-light leading-relaxed mb-4">
            When a new lead comes in through your website, a form, or an inbound text, they get an immediate response. Then a follow-up sequence runs automatically over the next 10 to 14 days.
          </p>
          <p class="text-ink-light leading-relaxed mb-4">
            The same applies to quotes. Once you send a quote, a follow-up sequence starts: a few short messages over one to two weeks, spaced to feel natural, not spammy. Most businesses never follow up more than once. This sequence does it for you.
          </p>
          <p class="text-ink-light leading-relaxed">
            You approve all the messages before anything goes live. If a customer responds at any point, the sequence pauses and the conversation routes to you.
          </p>
        </div>
        <DemoFollowUp />
      </div>

      <!-- Part 4 -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-20 items-start">
        <div>
          <div class="flex items-center gap-4 mb-6">
            <span class="flex-shrink-0 w-12 h-12 rounded-full bg-brand-600 text-white font-bold text-xl flex items-center justify-center" aria-hidden="true">4</span>
            <h3 class="text-2xl font-bold text-ink">Review Generation</h3>
          </div>
          <p class="text-ink-light leading-relaxed mb-4">
            After a job is complete, an automatic review request goes out to the customer by text. Short message, direct link to your Google profile. Takes them 30 seconds to tap and leave a review.
          </p>
          <p class="text-ink-light leading-relaxed mb-4">
            Most businesses do good work and have almost no reviews on Google because nobody ever asked at the right time. This fixes that.
          </p>
          <p class="text-ink-light leading-relaxed">
            More reviews means better placement in local search, which means more calls, which feeds back into the system.
          </p>
        </div>
        <DemoReviews />
      </div>
    </div>
  </section>

  <!-- First 30 days -->
  <section class="section-pad bg-warm-100 border-y border-warm-200" aria-labelledby="timeline-heading">
    <div class="section-container">
      <h2 id="timeline-heading" class="section-heading mb-4">What the First 30 Days Look Like</h2>
      <p class="section-sub max-w-2xl mb-16">
        From kickoff call to fully live, the whole process takes about a week. Here is the full timeline.
      </p>

      <div class="max-w-2xl space-y-0">
        {[
          {
            range: 'Days 1 to 3',
            title: 'Kickoff and Audit',
            body: 'We do a kickoff call, test your current setup the way a real customer would, and map every place where leads fall through. You see the same gaps your customers see.',
          },
          {
            range: 'Days 4 to 10',
            title: 'The Build',
            body: 'Website built or wired in, phone number provisioned, messages drafted with you, sequences built and tested. You approve every message before it goes live.',
          },
          {
            range: 'Days 11 to 14',
            title: 'Full Test Round',
            body: 'We run the full system as a test customer, from the Google search to the review request. Anything unexpected gets caught and fixed before launch.',
          },
          {
            range: 'Day 15',
            title: 'Live',
            body: 'The system goes live. We monitor the first two weeks closely and make adjustments as needed.',
          },
          {
            range: 'Days 15 to 30',
            title: 'Check-In Schedule',
            body: 'Weekly check-in calls for the first month. We look at what is coming in, refine messages where needed, and confirm everything is running as expected.',
          },
        ].map((step, i) => (
          <div class="flex gap-6 pb-10 relative">
            <div class="flex flex-col items-center">
              <div class="w-8 h-8 rounded-full bg-brand-600 text-white font-bold text-sm flex items-center justify-center flex-shrink-0 z-10" aria-hidden="true">
                {i + 1}
              </div>
              {i < 4 && <div class="w-0.5 flex-1 bg-warm-border mt-2" aria-hidden="true"></div>}
            </div>
            <div class="pb-2">
              <p class="text-xs font-semibold text-brand-600 uppercase tracking-wider mb-1">{step.range}</p>
              <h3 class="font-semibold text-ink mb-2">{step.title}</h3>
              <p class="text-ink-light leading-relaxed text-sm">{step.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing: same two packages as /pricing, one shared component -->
  <section id="pricing" class="section-pad bg-white" aria-labelledby="hiw-pricing-heading">
    <div class="section-container">
      <h2 id="hiw-pricing-heading" class="section-heading mb-4 text-center reveal">What It Costs</h2>
      <p class="section-sub max-w-2xl mx-auto mb-16 text-center reveal">
        Two packages, no long contract. Every agreement includes a 90-day out clause.
      </p>

      <PricingCards />
    </div>
  </section>

  <!-- FAQ -->
  <section class="section-pad bg-warm-100 border-y border-warm-200" aria-labelledby="faq-heading">
    <div class="section-container">
      <h2 id="faq-heading" class="section-heading mb-4">Common Questions</h2>
      <p class="section-sub max-w-xl mb-16">Straight answers to what most owners ask before they decide.</p>

      <div class="max-w-3xl divide-y divide-warm-200 border-t border-warm-200">
        {faqs.map(item => (
          <details class="group py-1">
            <summary class="flex items-center justify-between py-5 cursor-pointer list-none text-ink font-semibold text-lg hover:text-brand-600 transition-colors [&::-webkit-details-marker]:hidden gap-4">
              {item.q}
              <span class="flex-shrink-0 w-6 h-6 rounded-full border border-warm-200 flex items-center justify-center text-ink-muted group-open:text-brand-600 group-open:border-brand-200 group-open:bg-brand-50 transition-colors">
                <svg class="w-3.5 h-3.5 transition-transform group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12M6 12h12" />
                </svg>
              </span>
            </summary>
            <div class="pb-5 text-ink-light leading-relaxed max-w-2xl">
              {item.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <CtaSection />

</BaseLayout>

<script>
  // Personalization: live-update every [data-biz] across all demos.
  (() => {
    const input = document.getElementById('demo-biz-input') as HTMLInputElement | null;
    if (!input) return;
    const KEY = 'ab-demo-biz';
    const FALLBACK = '[Business Name]';

    const apply = (raw: string) => {
      const value = raw.trim() || FALLBACK;
      document.querySelectorAll('[data-biz]').forEach((el) => { el.textContent = value; });
    };

    // Restore a name typed earlier this session
    const saved = sessionStorage.getItem(KEY);
    if (saved) { input.value = saved; apply(saved); }

    input.addEventListener('input', () => {
      apply(input.value);
      sessionStorage.setItem(KEY, input.value.trim());
    });
  })();
</script>
