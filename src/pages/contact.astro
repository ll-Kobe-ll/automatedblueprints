---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import { site } from '../data/site';

const title       = 'Contact Us: Quotes, Templates & Custom Work | Automated Blueprints';
const description = 'Get a quote for the Lead Flow System, ask a question about the templates, or scope custom agency work. Straight answers within a business day.';
---

<BaseLayout {title} {description} canonicalPath="/contact">

  <!-- Hero -->
  <section class="bg-ink text-white section-pad" aria-label="Contact hero">
    <div class="section-container">
      <p id="contact-eyebrow" class="text-brand-300 text-sm font-semibold uppercase tracking-wider mb-4">Get in Touch</p>
      <h1 id="contact-heading" class="text-white text-4xl md:text-5xl font-bold tracking-tight leading-tight max-w-2xl mb-6">
        Quotes, Template Questions, and Custom Work.
      </h1>
      <p id="contact-intro" class="text-white/75 text-xl leading-relaxed max-w-xl mb-6">
        Want a quote for the Lead Flow System, have a question before buying a template, or need a custom build for your agency? Tell us what you need and you will get a straight answer within a business day.
      </p>
      <p id="contact-alt" class="text-white/50 text-sm">
        Want to see what your lead leak costs first? Start with the <a href="/audit" class="text-brand-300 font-semibold hover:text-white transition-colors">free 60-second audit</a> instead.
      </p>
    </div>
  </section>

  <!-- Form + details -->
  <section class="section-pad bg-white" aria-label="Contact form">
    <div class="section-container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">

        <!-- Left: form -->
        <div>
          <h2 class="text-2xl font-bold text-ink mb-2">Send a Message</h2>
          <p id="contact-form-intro" class="text-ink-light mb-8 leading-relaxed">
            Tell us about your business and what you need: a quote, a template question, or a custom build. The more detail, the faster the useful answer.
          </p>
          <ContactForm />
        </div>

        <!-- Right: details -->
        <div class="lg:pt-14">
          <div class="space-y-10">
            <div>
              <p class="text-xs font-semibold text-ink-muted uppercase tracking-wider mb-3">Email</p>
              <a href={`mailto:${site.email}`} class="text-brand-600 font-medium hover:text-brand-700 transition-colors">
                {site.email}
              </a>
            </div>

            <div>
              <p class="text-xs font-semibold text-ink-muted uppercase tracking-wider mb-3">Service Area</p>
              <p class="text-ink font-medium">{site.serviceArea}</p>
            </div>

            <div class="border-t border-warm-200 pt-10">
              <h3 class="text-lg font-semibold text-ink mb-3">What to Expect</h3>
              <ul class="space-y-3">
                {[
                  'A reply within one business day',
                  'A straight answer, no sales script',
                  'A real quote with real numbers, not a range that doubles later',
                  'If we are not the right fit, we will say so',
                ].map(item => (
                  <li class="flex items-start gap-3 text-ink-light">
                    <svg class="w-5 h-5 text-brand-600 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  // Arriving from a product CTA (?about=weekly-report): swap the page framing
  // so the click-promise ("Claim a Free 30-Day Trial") matches what they land on.
  (() => {
    const about = new URLSearchParams(window.location.search).get('about');
    if (about !== 'weekly-report') return;

    const set = (id: string, text: string) => {
      const el = document.getElementById(id);
      if (el) el.textContent = text;
    };
    set('contact-eyebrow', 'The Weekly Report: Early Access');
    set('contact-heading', 'Claim Your Free 30-Day Trial.');
    set('contact-intro', 'Tell us about your business and the tools you run on. We reply within a business day to book your 20-minute connection call, and your first report lands the following Monday. Free for 30 days.');
    set('contact-form-intro', 'Name, business, and email are all we need. If you want a head start, mention your accounting tool and CRM in the message box.');
    document.getElementById('contact-alt')?.classList.add('hidden');
  })();
</script>
