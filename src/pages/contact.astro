---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import { site } from '../data/site';

const title       = 'Book a Free 15-Minute Call | Automated Blueprints';
const description = 'Book a free 15-minute call with Automated Blueprints. No pitch deck, no pressure. We look at your current setup and show you exactly where leads are falling through.';
---

<BaseLayout {title} {description} canonicalPath="/contact">

  <!-- Hero -->
  <section class="bg-ink text-white section-pad" aria-label="Contact hero">
    <div class="section-container">
      <p class="text-brand-300 text-sm font-semibold uppercase tracking-wider mb-4">Get in Touch</p>
      <h1 class="text-white text-4xl md:text-5xl font-bold tracking-tight leading-tight max-w-2xl mb-6">
        15 Minutes. No Pitch. Just an Honest Look at Your Setup.
      </h1>
      <p class="text-white/75 text-xl leading-relaxed max-w-xl">
        Tell me what you are working with and what is not working. If there is a fit, we talk next steps. If not, I will say so.
      </p>
    </div>
  </section>

  <!-- Form + details -->
  <section class="section-pad bg-white" aria-label="Contact form">
    <div class="section-container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">

        <!-- Left: form -->
        <div>
          <h2 class="text-2xl font-bold text-ink mb-2">Send a Message</h2>
          <p class="text-ink-light mb-8 leading-relaxed">
            Fill out the form below. When you submit, you will get a response the same way we respond for our clients: within minutes. You will see exactly what your customers experience.
          </p>
          <ContactForm />
        </div>

        <!-- Right: details -->
        <div class="lg:pt-14">
          <div class="space-y-10">
            <div>
              <p class="text-xs font-semibold text-ink-muted uppercase tracking-wider mb-3">Email</p>
              <a href={`mailto:${site.email}`} class="text-brand-600 font-medium hover:text-brand-700 transition-colors">
                {site.email}
              </a>
            </div>

            <div>
              <p class="text-xs font-semibold text-ink-muted uppercase tracking-wider mb-3">Phone</p>
              <a href={`tel:${site.phone}`} class="text-brand-600 font-medium hover:text-brand-700 transition-colors">
                {site.phone}
              </a>
            </div>

            <div>
              <p class="text-xs font-semibold text-ink-muted uppercase tracking-wider mb-3">Service Area</p>
              <p class="text-ink font-medium">{site.serviceArea}</p>
            </div>

            <div class="border-t border-warm-200 pt-10">
              <h3 class="text-lg font-semibold text-ink mb-3">What to Expect</h3>
              <ul class="space-y-3">
                {[
                  'A response within minutes of your submission',
                  'A 15-minute call, no slides, no sales script',
                  'An honest read on where leads are slipping through',
                  'A clear answer on whether there is a fit',
                ].map(item => (
                  <li class="flex items-start gap-3 text-ink-light">
                    <svg class="w-5 h-5 text-brand-600 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
