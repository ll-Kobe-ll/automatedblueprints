---
import BaseLayout from '../layouts/BaseLayout.astro';
import TemplateCard from '../components/TemplateCard.astro';
import { templates } from '../data/templates';
import { included, license } from '../data/templateKit';
import { site } from '../data/site';

const title       = 'Website Templates for Agencies & Resellers | Automated Blueprints';
const description = 'Nine production-ready niche website templates, each running as a full live demo. Buy once, launch in an hour, use for unlimited clients.';

const bundleLive = !site.bundleUrl.startsWith('PASTE');
---

<BaseLayout {title} {description} canonicalPath="/templates">

  <!-- ============================================================
       HERO — agency / reseller primary
  ============================================================ -->
  <section class="bg-ink text-white section-pad" aria-label="Templates hero">
    <div class="section-container">
      <p class="text-brand-300 text-sm font-semibold uppercase tracking-wider mb-4">Templates for Agencies &amp; Resellers</p>
      <h1 class="text-white text-4xl md:text-5xl font-bold tracking-tight leading-tight max-w-3xl mb-6">
        Nine Niche Sites. Buy Once, Launch in an Hour.
      </h1>
      <p class="text-white/75 text-xl leading-relaxed max-w-2xl mb-10">
        Production-ready templates, each one running as a full live demo you can click through. Drop in the details and a finished site is live the same afternoon. Use them for as many clients as you want.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="#templates-grid" class="btn-primary-lg bg-white !text-brand-700 hover:bg-brand-50 focus-visible:outline-white">
          See the Templates
        </a>
        <a href="/contact" class="btn-ghost-lg border-white/30 text-white hover:bg-white/10 hover:border-white/50">
          Need Something Custom?
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       BUNDLE STRIP — the package offer, up front
  ============================================================ -->
  <section class="bg-brand-600" aria-label="Agency bundle offer">
    <div class="section-container py-6">
      <div class="flex flex-col md:flex-row md:items-center gap-4 md:gap-8">
        <div class="flex-1">
          <p class="text-white font-bold text-lg leading-snug">
            The Agency Bundle: all nine templates, {site.bundlePrice}.
          </p>
          <p class="text-white/80 text-sm mt-1">
            Unlimited client use, no royalties. Resell one site and it has paid for itself.
          </p>
        </div>
        <div class="flex items-center gap-4 md:flex-shrink-0">
          {bundleLive ? (
            <a href={site.bundleUrl} target="_blank" rel="noopener noreferrer" class="btn-primary bg-white !text-brand-700 hover:bg-brand-50 whitespace-nowrap">
              Get All Nine, {site.bundlePrice}
            </a>
          ) : (
            <span class="inline-flex items-center bg-white/15 text-white font-semibold px-6 py-3 rounded" aria-disabled="true">Opening soon</span>
          )}
          <a href="#bundle" class="text-white/90 text-sm font-semibold hover:text-white transition-colors whitespace-nowrap">Details &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       BUSINESS-OWNER ROUTING BANNER
  ============================================================ -->
  <section class="bg-brand-50 border-b border-brand-100" aria-label="For business owners">
    <div class="section-container py-8">
      <div class="flex flex-col md:flex-row md:items-center gap-5 md:gap-8">
        <div class="flex items-start gap-3 flex-1">
          <span class="w-10 h-10 rounded-lg bg-white border border-brand-100 flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-brand-600" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 01.75-.75h3a.75.75 0 01.75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349M3.75 21V9.349m0 0a3.001 3.001 0 003.75-.615A2.993 2.993 0 009.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 002.25 1.016c.896 0 1.7-.393 2.25-1.015a3.001 3.001 0 003.75.614m-16.5 0a3.004 3.004 0 01-.621-4.72L4.318 3.44A1.5 1.5 0 015.378 3h13.243a1.5 1.5 0 011.06.44l1.19 1.189a3 3 0 01-.621 4.72m-13.5 8.65h3.75a.75.75 0 00.75-.75V13.5a.75.75 0 00-.75-.75H6.75a.75.75 0 00-.75.75v3.75c0 .415.336.75.75.75z" />
            </svg>
          </span>
          <div>
            <p class="text-ink font-semibold">Not building sites for a living?</p>
            <p class="text-ink-light text-sm leading-relaxed">If you just want a site that works for your own business, we build, host, and run the whole thing for you. Start with a free look at where you are losing leads.</p>
          </div>
        </div>
        <div class="flex flex-col sm:flex-row gap-3 md:flex-shrink-0">
          <a href="/audit" class="btn-primary text-sm whitespace-nowrap">Get a Free Lead Audit</a>
          <a href="/how-it-works" class="btn-ghost text-sm whitespace-nowrap">See How It Works</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       WHAT EVERY TEMPLATE INCLUDES
  ============================================================ -->
  <section class="section-pad bg-white" aria-labelledby="included-heading">
    <div class="section-container">
      <h2 id="included-heading" class="section-heading mb-4 reveal">Every Template Comes Loaded</h2>
      <p class="section-sub max-w-2xl mb-16 reveal">
        Not a pretty shell. A complete, config-driven site with everything a local business actually needs, ready to deploy.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-10">
        {included.map((item, i) => (
          <div class="flex items-start gap-4 reveal" style={`--delay: ${(i % 3) * 80}ms`}>
            <span class="w-10 h-10 rounded-lg bg-brand-50 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-brand-600" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
              </svg>
            </span>
            <div>
              <h3 class="font-semibold text-ink mb-1.5">{item.title}</h3>
              <p class="text-ink-light text-sm leading-relaxed">{item.body}</p>
            </div>
          </div>
        ))}
      </div>

      <p class="text-ink-muted text-sm mt-12 reveal">With your content ready, you go from purchase to a live, deployed site in 30 to 60 minutes.</p>

      <!-- What you actually download -->
      <div class="mt-16 bg-warm-100 border border-warm-200 rounded-xl p-8 md:p-10 reveal">
        <h3 class="text-xl font-bold text-ink mb-2">What You Actually Download</h3>
        <p class="text-ink-light mb-8 max-w-2xl">One zip, delivered right after checkout. No account to make, no drip-fed lessons. Everything below is in the file:</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-4 max-w-3xl">
          {[
            'The complete source code: every page, component, and image',
            'Quick-start README: three commands to a running site',
            'Deploy guide for Cloudflare Pages, Netlify, and Vercel',
            'AI setup prompt: paste it into ChatGPT or Claude to customize fast',
            'Reseller guide: pricing, packaging, and client handoff',
            'The license in writing: unlimited client use, no royalties',
          ].map(item => (
            <div class="flex items-start gap-3 text-ink-light text-sm leading-relaxed">
              <svg class="w-5 h-5 text-brand-600 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
              {item}
            </div>
          ))}
        </div>
        <p class="text-ink-muted text-sm mt-8">All sales on digital downloads are final, so click through the live demos first and see exactly what you are getting. If anything in your download is broken, <a href={`mailto:${site.email}`} class="text-brand-600 font-semibold hover:text-brand-700 transition-colors">email us</a> and we will make it right. Full details in the <a href="/terms" class="text-brand-600 font-semibold hover:text-brand-700 transition-colors">terms</a>. Questions before you buy? Same email, straight answer.</p>
      </div>
    </div>
  </section>

  <!-- ============================================================
       THE 9 GRID
  ============================================================ -->
  <section id="templates-grid" class="section-pad bg-warm-100 border-y border-warm-200" aria-labelledby="grid-heading">
    <div class="section-container">
      <h2 id="grid-heading" class="section-heading mb-4 reveal">Pick Your Niche</h2>
      <p class="section-sub max-w-2xl mb-16 reveal">Nine industries, each with its own look. {site.templatePrice} per template or {site.bundlePrice} for all nine — and every purchase includes unlimited client use, no royalties. Resell one and it has paid for itself.</p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {templates.map((template, i) => (
          <div class="reveal" style={`--delay: ${(i % 3) * 80}ms`}>
            <TemplateCard {template} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       TRUST STRIP
  ============================================================ -->
  <section class="section-pad bg-white" aria-label="Proof">
    <div class="section-container">
      <div class="max-w-3xl reveal">
        <h2 class="section-heading mb-5">Not Mockups. Nine Deployed Sites.</h2>
        <p class="text-lg text-ink-light leading-relaxed mb-6">
          Every template above runs as a full, live demo — real pages, real forms, real speed you can test on your own phone. Click through any of them end to end before you spend a dollar.
        </p>
        <a href="#templates-grid" class="btn-ghost">Browse the Demos</a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       AGENCY BUNDLE + CUSTOM WORK
  ============================================================ -->
  <section id="bundle" class="section-pad bg-ink text-white" aria-labelledby="bundle-heading">
    <div class="section-container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">

        <!-- Bundle -->
        <div class="reveal">
          <p class="text-brand-300 text-sm font-semibold uppercase tracking-wider mb-4">Agency Bundle</p>
          <h2 id="bundle-heading" class="text-white text-3xl md:text-4xl font-bold tracking-tight mb-5">
            All Nine Templates, {site.bundlePrice}.
          </h2>
          <p class="text-white/75 text-lg leading-relaxed mb-6">
            Every niche, yours to reuse across unlimited clients with no per-site fees. One project pays it back. Built to be reskinned fast for whoever you sign next.
          </p>
          <ul class="space-y-3 mb-8">
            {license.map(item => (
              <li class="flex items-start gap-3 text-white/85">
                <svg class="w-5 h-5 text-brand-300 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
          {bundleLive ? (
            <a href={site.bundleUrl} target="_blank" rel="noopener noreferrer" class="btn-primary-lg bg-white !text-brand-700 hover:bg-brand-50 focus-visible:outline-white">
              Get All Nine, {site.bundlePrice}
            </a>
          ) : (
            <span class="inline-flex items-center bg-white/15 text-white font-semibold px-8 py-4 rounded text-lg" aria-disabled="true">Bundle opening soon</span>
          )}
        </div>

        <!-- Custom work -->
        <div class="bg-white/5 border border-white/10 rounded-xl p-8 reveal">
          <h3 class="text-white text-xl font-bold mb-3">Need a Custom Niche or Bulk Build?</h3>
          <p class="text-white/70 leading-relaxed mb-6">
            Want a template for a niche that is not here, a set built for your stack, or done-for-you customization on the whole bundle? Tell us what you need and we will scope it.
          </p>
          <a href="/contact" class="btn-primary-lg bg-brand-600 hover:bg-brand-700 text-white">
            Contact Me
          </a>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>
