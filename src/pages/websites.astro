---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaSection from '../components/CtaSection.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { site } from '../data/site';
import { projects } from '../data/projects';

const title       = 'The Lead Flow System: Website + Lead Capture, Done for You | Automated Blueprints';
const description = 'The whole lead flow done for you: a website that gets you found, instant response to every lead, automatic follow-up, and a review engine. Built and run for local businesses.';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'The Lead Flow System',
  serviceType: 'Website design, lead capture, and follow-up automation',
  description:
    'A done-for-you lead system for local businesses: a website built to get found, missed-call text-back, automatic follow-up, and review generation.',
  provider: {
    '@type': 'LocalBusiness',
    name: site.name,
    url: site.domain,
  },
  areaServed: 'US',
};
---

<BaseLayout {title} {description} canonicalPath="/websites" schema={serviceSchema}>

  <!-- ============================================================
       HERO
  ============================================================ -->
  <section class="bg-ink text-white" aria-label="Hero">
    <div class="section-container py-16 md:py-32">
      <p class="text-brand-300 text-sm font-semibold uppercase tracking-wider mb-5">
        The Lead Flow System
      </p>
      <h1 class="text-white text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight leading-tight max-w-3xl mb-6">
        Get Found. Catch Every Lead. Done for You.
      </h1>
      <p class="text-white/75 text-xl md:text-2xl leading-relaxed max-w-2xl mb-10">
        It starts with a website that gets you found. Then the system answers new leads in seconds, follows up until they book, and stacks your reviews, on its own. The whole lead flow, built and run for you.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href={site.ctaHref} class="btn-primary-lg bg-white !text-brand-700 hover:bg-brand-50 focus-visible:outline-white text-center">
          {site.ctaText}
        </a>
        <a href="/how-it-works" class="btn-ghost-lg border-white/30 text-white hover:bg-white/10 hover:border-white/50 text-center">
          See How It Works
        </a>
      </div>
      <p class="text-white/60 text-sm mt-6">
        Flat monthly pricing from {site.sitePrice}/month, no long contract. <a href="#pricing" class="text-brand-300 font-semibold hover:text-white transition-colors">See pricing &darr;</a>
      </p>
    </div>
  </section>

  <!-- ============================================================
       THE LEAK — 3 cards
  ============================================================ -->
  <section class="section-pad bg-white" aria-labelledby="leak-heading">
    <div class="section-container">
      <h2 id="leak-heading" class="section-heading mb-4 reveal">
        Where the Jobs Leak Out
      </h2>
      <p class="section-sub max-w-2xl mb-16 reveal">
        Three gaps cost local businesses work before they ever get a chance to quote it.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="card reveal" style="--delay: 0ms">
          <div class="w-11 h-11 rounded-lg bg-brand-50 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-brand-600" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-ink mb-3">They Can't Find You</h3>
          <p class="text-ink-light leading-relaxed">
            If you are not on the first page when someone searches for what you do, the call goes to whoever is. People do not scroll to page two. They tap the first business that looks real.
          </p>
        </div>
        <div class="card reveal" style="--delay: 100ms">
          <div class="w-11 h-11 rounded-lg bg-brand-50 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-brand-600" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-ink mb-3">You Look Closed</h3>
          <p class="text-ink-light leading-relaxed">
            A missing site, or one that has not been touched in years, reads as out of business. People trust their gut in two seconds. A dead web presence tells them to keep looking.
          </p>
        </div>
        <div class="card reveal" style="--delay: 200ms">
          <div class="w-11 h-11 rounded-lg bg-brand-50 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-brand-600" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 3.75H6.912a2.25 2.25 0 00-2.15 1.588L2.35 13.177a2.25 2.25 0 00-.1.661V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18v-4.162c0-.224-.034-.447-.1-.661L19.24 5.338a2.25 2.25 0 00-2.15-1.588H15M2.25 13.5h3.86a2.25 2.25 0 012.012 1.244l.256.512a2.25 2.25 0 002.013 1.244h3.218a2.25 2.25 0 002.013-1.244l.256-.512a2.25 2.25 0 012.013-1.244h3.859M12 3v8.25m0 0l-3-3m3 3l3-3" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-ink mb-3">The Site Doesn't Catch the Lead</h3>
          <p class="text-ink-light leading-relaxed">
            Even when they find you and reach out, a site with no follow-up lets the lead sit. By the time you reply, they booked someone faster. The site has to hand the lead straight to a system that responds.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       LIVE PROOF — data-driven from src/data/projects.ts
  ============================================================ -->
  <section class="section-pad bg-warm-100 border-y border-warm-200" aria-labelledby="proof-heading">
    <div class="section-container">
      <p class="text-brand-600 text-sm font-semibold uppercase tracking-wider mb-4 reveal">Live Demos</p>
      <h2 id="proof-heading" class="section-heading mb-4 reveal">
        {projects.length > 1 ? 'See What We Build, Live' : 'See One We Built, Live'}
      </h2>
      <p class="section-sub max-w-2xl mb-12 reveal">
        {projects.length > 1
          ? 'Live demo sites we have built, one per industry. Every one is a real, deployed site. Click any of them and look around.'
          : 'Not a mockup. A real site running right now. Click it and look around.'}
      </p>

      <div class:list={[
        'grid gap-8',
        projects.length > 1 ? 'md:grid-cols-2' : 'max-w-3xl mx-auto',
      ]}>
        {projects.map(project => <ProjectCard {project} />)}
      </div>

      <!-- ============================================================
           TESTIMONIAL PLACEHOLDER
           Drop a real client quote here the moment there is one.
           Keep the same card styling. Do not fabricate a quote.
           Example structure:
           <blockquote class="max-w-2xl mx-auto mt-12 bg-white border border-warm-200 rounded-lg p-8">
             <p class="text-ink text-lg leading-relaxed mb-4">"REAL QUOTE HERE."</p>
             <footer class="text-ink-muted text-sm font-medium">Name, Business Name</footer>
           </blockquote>
      ============================================================ -->

      <!-- Catch them at peak interest, right under the proof -->
      <div class="mt-14 flex flex-col sm:flex-row items-center justify-center gap-x-5 gap-y-4 text-center">
        <p class="text-ink font-semibold text-lg">Want one like these for your business?</p>
        <a href={site.ctaHref} class="btn-primary group">
          {site.ctaText}
          <svg class="w-4 h-4 ml-1.5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>

    </div>
  </section>

  <!-- ============================================================
       THE BUNDLE — how it fits with the engine
  ============================================================ -->
  <section class="section-pad bg-white" aria-labelledby="bundle-heading">
    <div class="section-container">
      <h2 id="bundle-heading" class="section-heading mb-5 reveal">
        The Site Gets You Found. The System Catches the Lead.
      </h2>
      <p class="text-lg md:text-xl text-ink-light leading-relaxed max-w-3xl mb-12 reveal">
        A website with no follow-up is half the job. A follow-up system with no site to feed it is the other half. Together they are one thing: get found, then catch every lead that comes in.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-warm-100 border border-warm-200 rounded-lg p-8 reveal" style="--delay: 0ms">
          <div class="w-10 h-10 rounded-full bg-brand-600 text-white font-bold flex items-center justify-center mb-4 text-sm" aria-hidden="true">1</div>
          <h3 class="font-semibold text-ink mb-2 text-lg">The Website</h3>
          <p class="text-ink-light leading-relaxed">
            The front door. Fast, clean, and built so you actually show up when people search for what you do. Most local competitors have nothing real online, so a proper site puts you ahead of them.
          </p>
        </div>
        <div class="bg-warm-100 border border-warm-200 rounded-lg p-8 reveal" style="--delay: 120ms">
          <div class="w-10 h-10 rounded-full bg-brand-600 text-white font-bold flex items-center justify-center mb-4 text-sm" aria-hidden="true">2</div>
          <h3 class="font-semibold text-ink mb-2 text-lg">The Capture Engine</h3>
          <p class="text-ink-light leading-relaxed">
            Every lead the site brings in gets an instant response and an automatic follow-up. Missed calls get a text back. Quotes get chased. Nothing the site earns you slips through.
          </p>
        </div>
      </div>

      <div class="mt-12">
        <a href="/how-it-works" class="btn-ghost">
          See How the System Works
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       PRICING — two tiers, flat monthly
  ============================================================ -->
  <section id="pricing" class="section-pad bg-warm-100 border-y border-warm-200" aria-labelledby="pricing-heading">
    <div class="section-container">
      <h2 id="pricing-heading" class="section-heading mb-4 text-center reveal">Simple Monthly Pricing</h2>
      <p class="section-sub max-w-2xl mx-auto mb-16 text-center reveal">
        No five-figure agency quote and no long contract. Every agreement includes a 90-day out clause.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto items-stretch">

        <!-- Tier 1: website only -->
        <div class="flex flex-col bg-white border border-warm-200 rounded-xl p-8 reveal" style="--delay: 0ms">
          <h3 class="text-lg font-semibold text-ink mb-1">The Website</h3>
          <p class="text-ink-muted text-sm mb-5">For businesses that just need to get found.</p>
          <p class="mb-6"><span class="text-4xl font-bold text-ink">{site.sitePrice}</span><span class="text-ink-muted text-sm">/month</span></p>
          <ul class="space-y-3 mb-8 flex-1">
            {[
              'Design, build, and copy done for you',
              'Hosting, updates, and edits included',
              'Built to rank for your trade and your area',
              'Every lead goes straight to your phone',
            ].map(item => (
              <li class="flex items-start gap-3 text-ink-light text-sm leading-relaxed">
                <svg class="w-5 h-5 text-brand-600 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
          <a href={site.ctaHref} class="btn-ghost w-full justify-center">Start With the Free Audit</a>
        </div>

        <!-- Tier 2: the full system (flagship) -->
        <div class="relative flex flex-col bg-ink text-white border-2 border-brand-600 rounded-xl p-8 reveal" style="--delay: 120ms">
          <span class="absolute -top-3.5 left-1/2 -translate-x-1/2 bg-brand-600 text-white text-xs font-bold uppercase tracking-wider px-3 py-1.5 rounded-full whitespace-nowrap">Most Popular</span>
          <h3 class="text-lg font-semibold text-white mb-1">The Lead Flow System</h3>
          <p class="text-white/60 text-sm mb-5">Never drop a lead again.</p>
          <p class="mb-1"><span class="text-4xl font-bold text-white">{site.systemPrice}</span><span class="text-white/60 text-sm">/month</span></p>
          <p class="text-white/50 text-xs mb-6">Plugs into your current website, or the one we build.</p>
          <ul class="space-y-3 mb-8 flex-1">
            {[
              'Missed-call text-back in under 60 seconds',
              'Automatic lead and quote follow-up',
              'Review requests after every job',
              'One simple inbox for every conversation',
              'Works with your existing website and number',
              'Monitored and tuned for you every month',
            ].map(item => (
              <li class="flex items-start gap-3 text-white/85 text-sm leading-relaxed">
                <svg class="w-5 h-5 text-brand-300 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
          <a href={site.ctaHref} class="btn-primary-lg bg-white !text-brand-700 hover:bg-brand-50 w-full justify-center text-base">Get a Free Lead Audit</a>
        </div>
      </div>

      <p class="text-ink-muted text-sm text-center mt-8 reveal">
        Two separate packages. Take the one you need, or run both together and the site feeds the system every lead it earns.
        Not sure? The free audit shows you what the leak costs, so the answer is usually obvious.
      </p>
    </div>
  </section>

  <!-- ============================================================
       STATS — sourced third-party research only
  ============================================================ -->
  <section class="bg-ink text-white section-pad" aria-label="Search research">
    <div class="section-container">
      <h2 class="text-white text-3xl md:text-4xl font-bold tracking-tight mb-16 text-center">
        Why Getting Found Matters
      </h2>

      <div class="max-w-xl mx-auto text-center reveal">
        <p class="text-6xl md:text-7xl font-bold text-brand-300 mb-4">98%</p>
        <p class="text-white/80 text-lg leading-relaxed">
          98% of people used the internet to find a local business in the past year. If nothing comes up when they search for you, you are not in the running.
        </p>
        <p class="text-white/55 text-xs mt-4">BrightLocal Local Consumer Review Survey, 2023</p>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CLOSING CTA
  ============================================================ -->
  <CtaSection
    variant="light"
    heading="Ready to Get Found and Stop Losing Leads?"
    body="Start with the free lead audit. Sixty seconds, no call, and you get a personalized video showing exactly where your leads are leaking and what the system would fix."
  />

</BaseLayout>
