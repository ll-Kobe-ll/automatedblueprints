---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaSection from '../components/CtaSection.astro';
import PathChooser from '../components/PathChooser.astro';
import DemoTextBack from '../components/DemoTextBack.astro';
import { site } from '../data/site';
import { projects } from '../data/projects';

const title       = 'Automated Blueprints | The Lead Flow System for Local Businesses';
const description = 'Missed calls, slow follow-up, and ignored quotes cost local businesses jobs every week. The Lead Flow System gets you found, responds in under 60 seconds, follows up automatically, and keeps leads from going cold.';

const proof = projects.filter(p => p.screenshot).slice(0, 3);
---

<BaseLayout {title} {description} canonicalPath="/">

  <!-- ============================================================
       HERO
  ============================================================ -->
  <section class="bg-ink text-white" aria-label="Hero">
    <div class="section-container py-16 md:py-32">
      <div class="lg:grid lg:grid-cols-[1fr,26rem] lg:gap-16 lg:items-center">
        <div>
          <p class="text-brand-300 text-sm font-semibold uppercase tracking-wider mb-5 hero-fade" style="--delay: 0ms">
            For Local Businesses Everywhere
          </p>
          <h1 class="text-white text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight leading-tight max-w-3xl mb-6 hero-fade" style="--delay: 120ms">
            The First Business to Answer Gets the Job.
          </h1>
          <p class="text-white/75 text-xl md:text-2xl leading-relaxed max-w-2xl mb-6 hero-fade" style="--delay: 240ms">
            Your missed calls, unanswered texts, and ignored follow-ups are sending customers to whoever shows up next. The Lead Flow System fixes all of it, in about a week.
          </p>
          <p class="text-white/60 text-lg leading-relaxed max-w-2xl mb-10 hero-fade" style="--delay: 340ms">
            It starts with a website that gets you found, then a system that catches every lead it brings in.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 hero-fade" style="--delay: 460ms">
            <a href={site.ctaHref} class="btn-primary-lg bg-white text-brand-700 hover:bg-brand-50 text-center">
              {site.ctaText}
            </a>
            <a href="/how-it-works" class="btn-ghost-lg border-white/30 text-white hover:bg-white/10 hover:border-white/50 text-center">
              See How It Works
            </a>
          </div>
        </div>

        <!-- Live demo: the system answering a missed call, right in the hero -->
        <div class="hidden lg:block hero-fade" style="--delay: 560ms">
          <DemoTextBack />
          <p class="text-white/50 text-xs text-center mt-3">Live demo: what your customers get when you cannot pick up. <a href="/how-it-works" class="text-brand-300 font-semibold hover:text-white transition-colors">See the whole system &rarr;</a></p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       PATH CHOOSER — four ways to work with me
  ============================================================ -->
  <PathChooser variant="warm" />

  <!-- ============================================================
       THE PROBLEM — 3 cards
  ============================================================ -->
  <section class="section-pad bg-white" aria-labelledby="problem-heading">
    <div class="section-container">
      <h2 id="problem-heading" class="section-heading mb-4 reveal">
        Where Local Businesses Lose Work Every Week
      </h2>
      <p class="section-sub max-w-2xl mb-16 reveal">
        None of these problems show up on a report. They are just jobs you never knew you missed.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="card card-hover reveal" style="--delay: 0ms">
          <div class="w-10 h-10 rounded-md bg-red-50 flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-red-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 4.5l-15 15" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-ink mb-3">Missed Calls, No Follow-Up</h3>
          <p class="text-ink-light leading-relaxed">
            Every call you cannot answer while you are busy is a lead that moves on. The average business takes 42 hours to follow up on a new inquiry. By then, the customer has already booked.
          </p>
        </div>
        <div class="card card-hover reveal" style="--delay: 100ms">
          <div class="w-10 h-10 rounded-md bg-amber-50 flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-amber-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-ink mb-3">Quotes That Go Cold</h3>
          <p class="text-ink-light leading-relaxed">
            You sent the estimate. They said they would think about it. Most businesses follow up once, maybe twice, then write the lead off. But 80% of sales take five or more follow-ups to close.
          </p>
        </div>
        <div class="card card-hover reveal" style="--delay: 200ms">
          <div class="w-10 h-10 rounded-md bg-amber-50 flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-amber-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-ink mb-3">No System for Reviews</h3>
          <p class="text-ink-light leading-relaxed">
            You do good work. Your customers know it. But you never ask at the right time, so reviews do not stack up, and businesses with more stars on Google keep winning the search.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SOLUTION — the Lead Flow System, 4 parts
  ============================================================ -->
  <section class="section-pad bg-warm-100 border-y border-warm-200" aria-labelledby="solution-heading">
    <div class="section-container">
      <p class="text-brand-600 text-sm font-semibold uppercase tracking-wider mb-4 reveal">The Lead Flow System</p>
      <h2 id="solution-heading" class="section-heading mb-4 reveal">
        One System That Gets You Found and Never Drops a Lead
      </h2>
      <p class="section-sub max-w-2xl mb-16 reveal">
        Four parts, built and run for you. The site brings the leads in, the other three make sure none of them slip away.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 md:gap-10">
        <div class="reveal" style="--delay: 0ms">
          <div class="step-number" aria-hidden="true">1</div>
          <h3 class="text-xl font-semibold text-ink mb-3">A Site That Gets You Found</h3>
          <p class="text-ink-light leading-relaxed">
            A fast website built to show up when people search for what you do. Most local competitors have nothing real online, so this alone puts you ahead of them.
          </p>
        </div>

        <div class="reveal" style="--delay: 100ms">
          <div class="step-number" aria-hidden="true">2</div>
          <h3 class="text-xl font-semibold text-ink mb-3">Missed Call Text-Back</h3>
          <p class="text-ink-light leading-relaxed">
            Any call you cannot answer gets an automatic text back in under 60 seconds, on a local number with your area code. The customer knows someone is there.
          </p>
        </div>

        <div class="reveal" style="--delay: 200ms">
          <div class="step-number" aria-hidden="true">3</div>
          <h3 class="text-xl font-semibold text-ink mb-3">Instant Response + Follow-Up</h3>
          <p class="text-ink-light leading-relaxed">
            New leads and quotes get an immediate reply, then a follow-up sequence runs for 10 to 14 days. No lead goes cold because no one remembered to follow up.
          </p>
        </div>

        <div class="reveal" style="--delay: 300ms">
          <div class="step-number" aria-hidden="true">4</div>
          <h3 class="text-xl font-semibold text-ink mb-3">Automatic Review Requests</h3>
          <p class="text-ink-light leading-relaxed">
            After a job is done, a short review request goes out by text. Reviews stack up, you rank higher, and the whole flow feeds itself.
          </p>
        </div>
      </div>

      <div class="mt-14 text-center reveal">
        <a href="/how-it-works" class="btn-primary">
          See the Full System, Live
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       PROOF STRIP — real work, live
  ============================================================ -->
  <section class="section-pad bg-white" aria-labelledby="proof-strip-heading">
    <div class="section-container">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-10">
        <div>
          <h2 id="proof-strip-heading" class="section-heading mb-3 reveal">Real Work, Live Right Now</h2>
          <p class="text-ink-light text-lg reveal">Not mockups. Click any of them and look around.</p>
        </div>
        <a href="/websites" class="text-brand-600 font-semibold whitespace-nowrap hover:text-brand-700 transition-colors reveal">See what we build &rarr;</a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        {proof.map((p, i) => (
          <a href={p.url} target="_blank" rel="noopener noreferrer" class="block border border-warm-200 rounded-xl overflow-hidden bg-white card-hover reveal" style={`--delay: ${i * 100}ms`} aria-label={`Open ${p.name} in a new tab`}>
            <div class="aspect-[16/10] bg-warm-100 overflow-hidden">
              <img src={p.screenshot} alt={`Screenshot of the ${p.name} website`} width="1000" height="625" loading="lazy" decoding="async" class="w-full h-full object-cover object-top" />
            </div>
            <div class="p-4 flex items-center justify-between gap-3">
              <div>
                <p class="font-semibold text-ink text-sm">{p.name}</p>
                <p class="text-ink-muted text-xs">{p.descriptor}</p>
              </div>
              {p.type === 'client' ? (
                <span class="text-xs font-semibold bg-green-50 text-green-700 px-2 py-1 rounded whitespace-nowrap">Live client</span>
              ) : (
                <span class="text-xs font-semibold bg-warm-100 text-ink-muted px-2 py-1 rounded whitespace-nowrap">Template demo</span>
              )}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       FLAGSHIP BAND — done for you
  ============================================================ -->
  <section class="bg-ink text-white section-pad" aria-labelledby="websites-heading">
    <div class="section-container">
      <div class="md:flex md:items-center md:justify-between md:gap-12 reveal">
        <div class="max-w-2xl">
          <p class="text-brand-300 text-sm font-semibold uppercase tracking-wider mb-4">Done For You</p>
          <h2 id="websites-heading" class="text-white text-3xl md:text-4xl font-bold tracking-tight mb-5">
            Want the Whole Thing Built and Run for You?
          </h2>
          <p class="text-white/75 text-lg leading-relaxed">
            We build the site, wire in the capture engine, and run it all in the background. You keep doing the work. The proof is live and clickable, real deployed sites you can walk through right now.
          </p>
        </div>
        <div class="mt-8 md:mt-0 flex-shrink-0">
          <a href="/websites" class="btn-primary-lg bg-white !text-brand-700 hover:bg-brand-50 focus-visible:outline-white">
            See the Lead Flow System
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       WHO IT'S FOR — industry cards
  ============================================================ -->
  <section class="section-pad bg-white" aria-labelledby="industries-heading">
    <div class="section-container">
      <h2 id="industries-heading" class="section-heading mb-4 reveal">
        Built for Businesses That Work With Their Hands
      </h2>
      <p class="section-sub max-w-2xl mb-16 reveal">
        The problem is the same across industries. The first business to respond wins most of the work.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        <a
          href="/industries/precision-manufacturing"
          class="block border border-warm-200 rounded-lg p-8 card-hover group reveal"
          style="--delay: 0ms"
          aria-label="See our solution for Machine Shops and Fabricators"
        >
          <div class="w-10 h-10 rounded-md bg-brand-50 flex items-center justify-center mb-5 group-hover:bg-brand-100 transition-colors">
            <svg class="w-5 h-5 text-brand-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-ink mb-3 group-hover:text-brand-600 transition-colors">
            Machine Shops &amp; Fabricators
          </h3>
          <p class="text-ink-light text-sm leading-relaxed mb-5">
            Everyone on the floor means calls go to voicemail and RFQs sit in an unchecked inbox. Buyers choose the shop that responds first.
          </p>
          <span class="text-brand-600 text-sm font-semibold inline-flex items-center gap-1 group-hover:translate-x-1 transition-transform">
            See how it works <span aria-hidden="true">&rarr;</span>
          </span>
        </a>

        <a
          href="/industries/med-spas"
          class="block border border-warm-200 rounded-lg p-8 card-hover group reveal"
          style="--delay: 100ms"
          aria-label="See our solution for Med Spas and Aesthetic Practices"
        >
          <div class="w-10 h-10 rounded-md bg-brand-50 flex items-center justify-center mb-5 group-hover:bg-brand-100 transition-colors">
            <svg class="w-5 h-5 text-brand-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-ink mb-3 group-hover:text-brand-600 transition-colors">
            Med Spas &amp; Aesthetics
          </h3>
          <p class="text-ink-light text-sm leading-relaxed mb-5">
            Consult requests that go unanswered for hours, no-shows that could have been prevented, and clients who book once and never come back.
          </p>
          <span class="text-brand-600 text-sm font-semibold inline-flex items-center gap-1 group-hover:translate-x-1 transition-transform">
            See how it works <span aria-hidden="true">&rarr;</span>
          </span>
        </a>

        <a
          href="/industries/home-services"
          class="block border border-warm-200 rounded-lg p-8 card-hover group reveal"
          style="--delay: 200ms"
          aria-label="See our solution for Contractors and Home Services"
        >
          <div class="w-10 h-10 rounded-md bg-brand-50 flex items-center justify-center mb-5 group-hover:bg-brand-100 transition-colors">
            <svg class="w-5 h-5 text-brand-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-ink mb-3 group-hover:text-brand-600 transition-colors">
            Contractors &amp; Home Services
          </h3>
          <p class="text-ink-light text-sm leading-relaxed mb-5">
            Missed calls while you are on jobs, leads that go cold in hours, and no engine for stacking up Google reviews.
          </p>
          <span class="text-brand-600 text-sm font-semibold inline-flex items-center gap-1 group-hover:translate-x-1 transition-transform">
            See how it works <span aria-hidden="true">&rarr;</span>
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       FREE CRASH COURSE
  ============================================================ -->
  <section class="section-pad bg-warm-100 border-y border-warm-200" aria-labelledby="course-heading">
    <div class="section-container text-center reveal">
      <p class="text-brand-600 text-sm font-semibold uppercase tracking-wider mb-4">Free Course, No Email Required</p>
      <h2 id="course-heading" class="section-heading mb-4">
        See Exactly How the System Works
      </h2>
      <p class="section-sub max-w-2xl mx-auto mb-8">
        The Client Capture Crash Course: six short lessons with diagrams covering missed call text-back, speed to lead, follow-up sequences, reviews, reactivation, and no-show recovery.
      </p>
      <a href="/learn" class="btn-primary">
        Start the Free Course
      </a>
    </div>
  </section>

  <!-- ============================================================
       STATS — dark section
  ============================================================ -->
  <section class="bg-ink text-white section-pad" aria-label="Industry research">
    <div class="section-container">
      <h2 class="text-white text-3xl md:text-4xl font-bold tracking-tight mb-16 text-center reveal">
        The Numbers Behind the Problem
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16 max-w-3xl mx-auto text-center">
        <div class="reveal" style="--delay: 0ms">
          <p class="text-5xl md:text-6xl font-bold text-brand-300 mb-3 count-up" data-target="21" data-suffix="x">0x</p>
          <p class="text-white/80 leading-relaxed">
            Businesses that respond within 5 minutes are 21x more likely to qualify a lead than those who wait 30 minutes.
          </p>
          <p class="text-white/55 text-xs mt-3">Harvard Business Review, 2011 (study of 2,241 companies)</p>
        </div>

        <div class="reveal" style="--delay: 150ms">
          <p class="text-5xl md:text-6xl font-bold text-brand-300 mb-3 count-up" data-target="93" data-suffix="%">0%</p>
          <p class="text-white/80 leading-relaxed">
            93% of consumers say online reviews influence their purchasing decisions. Reviews are part of the sales process now.
          </p>
          <p class="text-white/55 text-xs mt-3">BrightLocal Consumer Review Survey, 2023</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CTA
  ============================================================ -->
  <CtaSection variant="light" />

</BaseLayout>

<style>
  /* Hero entrance — immediate on page load */
  .hero-fade {
    opacity: 0;
    transform: translateY(16px);
    animation: heroIn 0.6s ease forwards;
    animation-delay: var(--delay, 0ms);
  }
  @keyframes heroIn {
    to { opacity: 1; transform: translateY(0); }
  }

  /* Step number circles (reveal + .card-hover come from global.css) */
  .step-number {
    width: 3rem;
    height: 3rem;
    border-radius: 9999px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1.125rem;
    margin-bottom: 1.5rem;
    background: var(--brand-600, #2563eb);
    color: white;
    transition: transform 0.4s ease;
  }
  .reveal.is-visible .step-number {
    animation: popIn 0.4s ease forwards;
  }
  @keyframes popIn {
    0%   { transform: scale(0.6); }
    60%  { transform: scale(1.08); }
    100% { transform: scale(1); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-fade { opacity: 1; transform: none; animation: none; }
  }
</style>

<script>
  // Count-up animation for stat numbers
  const countObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const el = entry.target as HTMLElement;
        const target = parseInt(el.dataset.target || '0', 10);
        const suffix = el.dataset.suffix || '';
        const duration = 1200;
        const start = performance.now();

        function tick(now: number) {
          const elapsed = now - start;
          const progress = Math.min(elapsed / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          const current = Math.round(eased * target);
          el.textContent = current + suffix;
          if (progress < 1) requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
        countObserver.unobserve(el);
      });
    },
    { threshold: 0.3 }
  );

  document.querySelectorAll('.count-up').forEach((el) => countObserver.observe(el));
</script>
