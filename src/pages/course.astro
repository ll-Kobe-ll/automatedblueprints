---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';

const title       = 'The Course: Build & Launch Your Own Lead-Getting Site | Automated Blueprints';
const description = 'Get the templates plus a full walkthrough of setting up your site, hosting it, and wiring in the lead-capture system yourself. Everything we do, handed to you.';

const courseLive = !site.courseUrl.startsWith('PASTE');

const included = [
  { title: 'The template pack', body: 'The same niche templates we sell and use for clients. Yours to launch and reuse.' },
  { title: 'Step-by-step setup videos', body: 'Watch me set a template up from scratch. Colors, copy, photos, pages, the whole thing.' },
  { title: 'Hosting, done simply', body: 'How to get the site live on a fast, free host and point your domain at it. No guesswork.' },
  { title: 'The lead-capture setup', body: 'How to wire in the form, missed-call text-back, and follow-up so the site actually catches leads.' },
  { title: 'The exact tools we use', body: 'No fluff and no upsells. The real stack, why each piece is there, and how to keep costs low.' },
];

const faqs = [
  { q: 'Do I need to know how to code?', a: 'No. The whole point is that you follow along and copy what we do. If you can change text in a document, you can do this.' },
  { q: 'Can I use the templates for clients?', a: 'Yes. Once you have the course you can use the templates for your own business or for client work.' },
  { q: 'What if I get stuck?', a: 'The videos cover the spots people usually get stuck on. If something still trips you up, you can reach out.' },
];
---

<BaseLayout {title} {description} canonicalPath="/course" noIndex={true}>

  <!-- Hero -->
  <section class="bg-ink text-white section-pad" aria-label="Course hero">
    <div class="section-container">
      <p class="text-brand-300 text-sm font-semibold uppercase tracking-wider mb-4">The Course</p>
      <h1 class="text-white text-4xl md:text-5xl font-bold tracking-tight leading-tight max-w-3xl mb-6">
        Build It Yourself, the Way We Build It.
      </h1>
      <p class="text-white/75 text-xl leading-relaxed max-w-2xl mb-10">
        Get the templates plus a full walkthrough of setting up the site, hosting it, and wiring in the lead system. Everything we do for clients, handed to you to do on your own.
      </p>
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
        {courseLive ? (
          <a href={site.courseUrl} target="_blank" rel="noopener noreferrer" class="btn-primary-lg bg-white !text-brand-700 hover:bg-brand-50 focus-visible:outline-white">
            Get the Course, {site.coursePrice}
          </a>
        ) : (
          <span class="inline-flex items-center bg-white/15 text-white font-semibold px-8 py-4 rounded text-lg" aria-disabled="true">Enrollment opening soon</span>
        )}
        <span class="text-white/60 text-sm">One payment. Yours for good.</span>
      </div>
    </div>
  </section>

  <!-- What's included -->
  <section class="section-pad bg-white" aria-labelledby="included-heading">
    <div class="section-container">
      <h2 id="included-heading" class="section-heading mb-4">What You Get</h2>
      <p class="section-sub max-w-2xl mb-16">No filler. The templates and the exact steps to put them to work.</p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl">
        {included.map((item, i) => (
          <div class="flex items-start gap-4">
            <span class="flex-shrink-0 w-9 h-9 rounded-full bg-brand-50 text-brand-600 font-bold text-sm flex items-center justify-center mt-0.5">{i + 1}</span>
            <div>
              <h3 class="font-semibold text-ink mb-1.5">{item.title}</h3>
              <p class="text-ink-light text-sm leading-relaxed">{item.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Who it's for -->
  <section class="section-pad bg-warm-100 border-y border-warm-200" aria-labelledby="who-heading">
    <div class="section-container">
      <div class="max-w-3xl">
        <h2 id="who-heading" class="section-heading mb-5">Who This Is For</h2>
        <p class="text-lg text-ink-light leading-relaxed mb-4">
          The business owner who wants a real site but does not want to pay full done-for-you prices. The side-hustler who wants to build sites for others. Anyone who learns faster by watching someone do it than by reading docs.
        </p>
        <p class="text-ink-light leading-relaxed">
          If you would rather have it built and hosted for you, that is the <a href="/websites" class="text-brand-600 font-semibold hover:text-brand-700 transition-colors">done-for-you option</a> instead.
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section-pad bg-white" aria-labelledby="course-faq-heading">
    <div class="section-container">
      <h2 id="course-faq-heading" class="section-heading mb-12">Common Questions</h2>
      <div class="max-w-3xl divide-y divide-warm-200 border-t border-warm-200">
        {faqs.map((item) => (
          <details class="group py-1">
            <summary class="flex items-center justify-between py-5 cursor-pointer list-none text-ink font-semibold text-lg hover:text-brand-600 transition-colors [&::-webkit-details-marker]:hidden gap-4">
              {item.q}
              <span class="flex-shrink-0 w-6 h-6 rounded-full border border-warm-200 flex items-center justify-center text-ink-muted group-open:text-brand-600 group-open:border-brand-200 group-open:bg-brand-50 transition-colors">
                <svg class="w-3.5 h-3.5 transition-transform group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12M6 12h12" />
                </svg>
              </span>
            </summary>
            <div class="pb-5 text-ink-light leading-relaxed max-w-2xl">{item.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section-pad bg-brand-600" aria-label="Course call to action">
    <div class="section-container text-center">
      <h2 class="text-white text-3xl md:text-4xl font-bold tracking-tight mb-5">Ready to Build It?</h2>
      <p class="text-white/80 text-lg md:text-xl mb-8 max-w-2xl mx-auto leading-relaxed">
        Get the templates and the walkthrough, and have your own site live this week.
      </p>
      {courseLive ? (
        <a href={site.courseUrl} target="_blank" rel="noopener noreferrer" class="btn-primary-lg bg-white !text-brand-700 hover:bg-brand-50 focus-visible:outline-white">
          Get the Course, {site.coursePrice}
        </a>
      ) : (
        <span class="inline-flex items-center bg-white/15 text-white font-semibold px-8 py-4 rounded text-lg" aria-disabled="true">Enrollment opening soon</span>
      )}
    </div>
  </section>

</BaseLayout>
