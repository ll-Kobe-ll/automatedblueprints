---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaSection from '../components/CtaSection.astro';
import { site } from '../data/site';

const title       = 'About Automated Blueprints | Lead Response Systems';
const description = 'Automated Blueprints is run by one person based in Orange County, CA. I build lead capture and response systems for businesses anywhere. I do not manage a team. If you work with me, you work with me directly.';
---

<BaseLayout {title} {description} canonicalPath="/about">

  <!-- Hero -->
  <section class="bg-ink text-white section-pad" aria-label="About hero">
    <div class="section-container">
      <p class="text-brand-300 text-sm font-semibold uppercase tracking-wider mb-4">About</p>
      <h1 class="text-white text-4xl md:text-5xl font-bold tracking-tight leading-tight max-w-3xl mb-6">
        I Build Systems That Keep Businesses From Losing Work
      </h1>
      <p class="text-white/75 text-xl leading-relaxed max-w-xl">
        Based in Orange County, CA. One person, one focus.
      </p>
    </div>
  </section>

  <!-- Content -->
  <section class="section-pad bg-white" aria-label="About content">
    <div class="section-container">
      <div class="max-w-2xl">

        <div class="prose-style space-y-6 text-ink-light text-lg leading-relaxed">
          <p>
            I run Automated Blueprints out of Orange County, CA. I started this because I kept watching well-run businesses lose jobs for a reason that made no sense: they were too busy doing the work to answer the phone.
          </p>
          <p>
            A customer calls with a real job. Gets voicemail. Calls the next number. Books them. The business that missed the call never even knows it happened.
          </p>
          <p>
            That is a fixable problem. Most businesses just do not have a system in place for what happens before the first conversation.
          </p>

          <div class="border-l-4 border-brand-600 pl-6 py-1">
            <p class="text-ink font-medium">
              I build that system. It handles missed calls, lead follow-up, quote follow-up, and review generation, all automatically, while you do the actual work.
            </p>
          </div>

          <p>
            I am not an agency. I do not manage a team of contractors or outsource anything. If you work with me, you work with me directly. I come in person when that makes sense, usually for kickoff and the first check-in after you go live.
          </p>
          <p>
            I work with a limited number of clients at a time because I build and manage everything myself. That is how the quality stays consistent.
          </p>
          <p>
            If your business is losing work because of slow response or no follow-up, I would like to talk.
          </p>
        </div>

        <div class="mt-12 pt-10 border-t border-warm-200">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
            <div>
              <p class="text-xs font-semibold text-ink-muted uppercase tracking-wider mb-2">Location</p>
              <p class="text-ink font-medium">{site.location}</p>
            </div>
            <div>
              <p class="text-xs font-semibold text-ink-muted uppercase tracking-wider mb-2">Focus</p>
              <p class="text-ink font-medium">Lead capture and response systems for local businesses</p>
            </div>
            <div>
              <p class="text-xs font-semibold text-ink-muted uppercase tracking-wider mb-2">Approach</p>
              <p class="text-ink font-medium">One person. In-person when it makes sense. No outsourcing.</p>
            </div>
            <div>
              <p class="text-xs font-semibold text-ink-muted uppercase tracking-wider mb-2">Availability</p>
              <p class="text-ink font-medium">Limited client slots. Current availability by inquiry.</p>
            </div>
          </div>
        </div>

        <div class="mt-12">
          <a href={site.ctaHref} class="btn-primary-lg">
            {site.ctaText}
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
